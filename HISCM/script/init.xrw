	<xhtml:head>
		<xhtml:title>::: MATE-ERP :::</xhtml:title>
		<model id="model1">
			<instance id="instance1">
				<root xmlns="">
				</root>
			</instance>
		</model>
		<script type="javascript">
			<![CDATA[
//==================================================
// (주) 컴퓨터메이트 - 초기 로딩 공통 함수 선언
//================================================================
// ComMate: 타이틀 설정
//================================================================
function setTitle() 
{ try{
	docTitle = model.getValue("/root/setValue/docTitle");
	document.title = docTitle ;				
} catch(e) { model.alert(getFormID() + " => init => setTitle => " + e, "ComMate DEBUG"); return false; }}

//================================================================
// ComMate: 타이틀 설정
//================================================================
function copyUserInfo() 
{ try{
	// 메인에 있는 권한과 mdb 정보 복사
	// model.copyNode("/root/SESSION", parent.root.SESSION);
	model.copyNode("/root/cmdMdbUserInfo",parent.root.cmdMdbUserInfo);
	model.copyNode("/root/cmdPagePermit",parent.root.cmdPagePermit);
} catch(e) { model.alert(getFormID() + " => init => copyUserInfo => " + e, "ComMate DEBUG"); return false; }}

//================================================================
// ComMate: 버튼 컨트롤 배경 이미지 설정, 그리드 환경설정 저장 및 불러오기
//================================================================	
function setControls() 
{ try{
	var styleType = model.getValue("/root/cmdMdbUserInfo/styleType") ;
	var colorType = styleType.substring(0, 1);
	var obj = document.controls ;
	for (var i=0; i<obj.length; i++) {
		var ctrlEle = obj.item(i).elementName;
		if (ctrlEle == "xforms:button") { 
			var isGroup = obj.item(i).attribute("group") ;
			if (((isGroup == null) || (isGroup == "")) && obj.item(i).parent.elementName != "xforms:calendar" ) { // 일반 버튼 일 경우

				obj.item(i).text = replaceAll(obj.item(i).text, " ", ""); 
				var btnText = obj.item(i).text ;
				var btnLength = parseInt((getStrByte(btnText)+1)/2) ;
				
				if (btnLength>5) btnLength = 5 ;
				else if (btnLength<2) btnLength = 2 ;

				obj.item(i).attribute("style") = "background-image:../images/button/"+ colorType +"Length"+ btnLength +".jpg" ;
				obj.item(i).attribute("style") = "width:"+(55 + 15*(btnLength -2))+"px;"+"height:20px";
				obj.item(i).attribute("style") = "text-align:right;border-style:solid;padding-right:5;" ;

			} else { // 그룹 버튼 일 경우
				//obj.item(i).attribute("background-color") = color2 ;
				//obj.item(i).attribute("select.background-color") = color3 ;
			}
		} else if (ctrlEle == "xforms:datagrid") { // 그리드일 경우
			// 아이디를 gridList 에 추가
			obj.item(i).attribute("colsep") = "▤" ;
			obj.item(i).attribute("rowsep") = "▥" ;
			var pageSavePermit = model.getValue("/root/cmdPagePermit/XGSVYN") ; 
			if (pageSavePermit == "Y" && obj.item(i).attribute("rowheader") != "") {
				obj.item(i).attribute("rowheader") = "update" ;
			} else if (obj.item(i).attribute("rowheader") != "") {
				obj.item(i).attribute("rowheader") = "seq" ;
			}
			
			var cols = obj.item(i).cols;
			for(var j = 0; j < cols; j++) {
				
				if(obj.item(i).colAttribute(j,"visibility") == "hidden") {
					obj.item(i).colAttribute(j,"_hidden") = "2";
				} 
				
			}
			var gridID = obj.item(i).attribute("id") ;
			var gridList = model.getValue("/root/cmdPageGridList");
			
			gridList += "," + gridID ;
			model.setValue("/root/cmdPageGridList", gridList) ;
		} else if (ctrlEle == "xforms:upload") { // 파일 업로드 컨트롤일 경우
			obj.item(i).attribute("validate") = true ;
			var uploadFileSize = model.getValue("/root/setValue/uploadFileSize");
			obj.item(i).attribute("filesize") = uploadFileSize ;
			var uploadFileCount = model.getValue("/root/setValue/uploadFileCount");
			obj.item(i).attribute("filecount") = uploadFileCount ;
			var uploadFileExt = model.getValue("/root/setValue/uploadFileExt");
			if (uploadFileExt != "all" && uploadFileExt != "All" && uploadFileExt != null && uploadFileExt != "" ) {
				obj.item(i).attribute("ext") = uploadFileExt ;
			}
		} 
	}

	initSetGrid() ; // MDB 사용자 설정 정보를 통한 그리드 재구성 

} catch(e) { model.alert(getFormID() + " => init => setControls => " + e, "ComMate DEBUG"); return false; }}


