//***************************************************
// ComMate: 그리드 행내용을 디테일 그룹에 복사
//***************************************************
function gridDetail(groupControl, row) 
{ try{
	if(row != -1 && row != 0) {
		var obj = document.controls;
		for (var i=0 ; i<obj.length; i++) {
			try {
				var parentObj = obj.item(i).parent;
				while(parentObj.attribute("id") != groupControl && parentObj.elementName != "xhtml:body" ) {
					parentObj = parentObj.parent ;
				}
				if (parentObj.attribute("id") == groupControl) {
					if ((obj.item(i).attribute("ref").indexOf("gridData") != -1)&&(obj.item(i).attribute("ref").indexOf("item") != -1)) {
						var refList = obj.item(i).attribute("ref").split("/item");
						var refFirst = refList[0] ;
						var refLast = refList[1].split("/")[1];
						obj.item(i).attribute("ref") = refFirst + "/item["+row+"]/"+refLast ;
						obj.item(i).refresh();
					}
				}
			}catch(e) {}
		}
	}
} catch(e) { model.alert(getFormID() + " => function => gridDetail => " + e, "ComMate DEBUG"); return false; }}
//***************************************************
// ComMate: 입력 컨트롤 키이벤트에 대소문자 변환
//***************************************************
function convertCase(inputmode)
{ try{
   if ( (inputmode == "A") && (97 <= event.keyCode && event.keyCode <= 122) ) {
       event.keyCode -= 32;
       return;
   }
   else if ( (inputmode == "a") && (65 <= event.keyCode && event.keyCode <= 90) ) {
       event.keyCode += 32;
       return;
   }
} catch(e) { model.alert(getFormID() + " => function => convertCase => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 문자열 내의 앞 뒤 공백 제거
//***************************************************
function trim(str)
{ try{
	return str.replace(/(^\s*)|(\s*$)/gi, "");
} catch(e) { model.alert(getFormID() + " => function => trim => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 문자열내의 왼쪽 공백 제거
//***************************************************
function leftTrim(str)
{ try{
	return str.replace(/(^\s*)/g, "");
} catch(e) { model.alert(getFormID() + " => function => leftTrim => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 문자열내의 오른쪽 공백 제거
//***************************************************
function rightTrim(str)
{ try{
	return str.replace(/(\s*$)/g, "");
} catch(e) { model.alert(getFormID() + " => function => rightTrim => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 현재 로컬 시스템의 날짜 지정 포멧으로 반환
//***************************************************
function getDate(format)
{ try{
	var date = new Date();

	var y = date.getYear();
	var m = date.getMonth() + 1;
	var d = date.getDate();

	var ret = "";

	if (format == "yyyymmdd" || format == null) {
		ret += y;
		ret += (m < 10 ) ? "0" + m : m;
		ret += (d < 10 ) ? "0" + d : d;
	} else if (format == "yyyy-mm-dd") {
		ret += y;
		ret += "-";
		ret += (m < 10 ) ? "0" + m : m;
		ret += "-";
		ret += (d < 10 ) ? "0" + d : d;
	} else if (format == "yyyy/mm/dd") {
		ret += y;
		ret += "/";
		ret += (m < 10 ) ? "0" + m : m;
		ret += "/";
		ret += (d < 10 ) ? "0" + d : d;
	} else if (format == "yyyymm") {
		ret += y;
		ret += (m < 10 ) ? "0" + m : m;
	} else if (format == "yyyy/mm") {
		ret += y;
		ret += "/";
		ret += (m < 10 ) ? "0" + m : m;
	} else if (format == "yyyy-mm") {
		ret += y;
		ret += "-";
		ret += (m < 10 ) ? "0" + m : m;
	} else if (format == "mmdd") {
		ret += (m < 10 ) ? "0" + m : m;
		ret += (d < 10 ) ? "0" + d : d;
	} else if (format == "mm/dd") {
		ret += (m < 10 ) ? "0" + m : m;
		ret += "/" ;
		ret += (d < 10 ) ? "0" + d : d;
	} else if (format == "mm-dd") {
		ret += (m < 10 ) ? "0" + m : m;
		ret += "-" ;
		ret += (d < 10 ) ? "0" + d : d;
	} else if (format == "yyyy") 	{
		ret += y;
	} else if (format == "mm") 	{
		ret += (m < 10 ) ? "0" + m : m;
	} else if (format == "dd") 	{
		ret += (d < 10 ) ? "0" + d : d;
	} else {
		// 에러 처리
		ret += "err" ;
	}
	return ret;
} catch(e) { model.alert(getFormID() + " => function => getDate => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 현재 로컬 시스템의 시간을 지정 포멧으로 반환
//***************************************************
function getTime(format)
{ try{
	var date = new Date();

	var h = date.getHours();
	var m = date.getMinutes();
	var s = date.getSeconds();

	var ret = "";

	if (format == "hhmmss" || format == null) {
		ret += (h < 10 ) ? "0" + h : h;
		ret += (m < 10 ) ? "0" + m : m;
		ret += (s < 10 ) ? "0" + s : s;
	} else if (format == "hhmm") {
		ret += (h < 10 ) ? "0" + h : h;
		ret += (m < 10 ) ? "0" + m : m;
	} else if (format == "hh:mm:ss") {
		ret += (h < 10 ) ? "0" + h : h;
		ret += ":";
		ret += (m < 10 ) ? "0" + m : m;
		ret += ":";
		ret += (s < 10 ) ? "0" + s : s;
	} else if (format == "hh:mm") {
		ret += (h < 10 ) ? "0" + h : h;
		ret += ":";
		ret += (m < 10 ) ? "0" + m : m;
	} else if (format == "hh") {
		ret += (h < 10 ) ? "0" + h : h;
	} else if (format == "mm") {
		ret += (m < 10 ) ? "0" + m : m;
	} else {
		ret += "err";
	}
	return ret;
} catch(e) { model.alert(getFormID() + " => function => getTime => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 숫자 앞에 지정 자리수 만큼의 "0" 추가하기
//***************************************************
function addZero(num, len)
{ try{
	num = num.toString();
	if (num.length < len)
	{
		var space = "";
		var slen = len - num.length;
			for (var i = 0; i < slen; i++)
				space += "0";
		num = (space + num);
	}
	return num;
} catch(e) { model.alert(getFormID() + " => function => addZero => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 숫자 앞에 지정 자리수 만큼의 공백 추가하기
//***************************************************
function addSpace(num, len)
{ try{
	num = num.toString();
	if (num.length < len)
	{
		var space = "";
		var slen = len - num.length;
			for (var i = 0; i < slen; i++)
				space += " ";
		num = (space + num);
	}
	return num;
} catch(e) { model.alert(getFormID() + " => function => addSpace => " + e, "ComMate DEBUG"); return false; }}
//***************************************************
// ComMate: 지정한 날자형 문자열을 날자 포멧에 맞게 바꾸기
// 예: calDate(200711365) = > 2007년도 11월 365일 경과후 값: 20071030
//***************************************************
function calDate(sDate)
{ try{

    if( sDate != null ){

        var curYear = parseInt(sDate.substring(0,4), 10);
        var curMon  = parseInt(sDate.substring(4,6), 10) -1;
        var curDay  = parseInt(sDate.substring(6), 10);
    }

    var  objDate = ( sDate == null ? new Date() : new Date(curYear,curMon,curDay));

    var dateYear = objDate.getYear();
    var dateMonth = objDate.getMonth() + 1;
    var dateDay = objDate.getDate();

    dateMonth = (dateMonth < 10 ?  "0" + dateMonth : dateMonth);
    dateDay = (dateDay < 10 ?  "0" + dateDay : dateDay);

    var s = dateYear.toString();
    s += dateMonth.toString();
    s += dateDay.toString();

    return(s);

} catch(e) { model.alert(getFormID() + " => function => calDate => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 정해진 날자의 다음날 얻기
// 예: nextDate("20071120") => 리턴값: 20071121
//***************************************************
function nextDay(sDate)
{ try{
    if (sDate == "" || sDate == null) 
    	sDate = getDate() ;

    var trgDate = parseInt(sDate, 10) + 1;
    var strDate = trgDate.toString();

    return(calDate(strDate));

} catch(e) { model.alert(getFormID() + " => function => nextDay => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 정해진 날자의 이전날 얻기
// 예: nextDate("20071120") => 리턴값: 20071119
//***************************************************
function prevDay(sDate)
{ try{
	if (sDate == "" || sDate == null) 
		sDate = getDate() ;
		
	var trgDate = parseInt(sDate, 10) - 1;
	var strDate = trgDate.toString();

	return(calDate(strDate));
} catch(e) { model.alert(getFormID() + " => function => prevDay => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 지정한 년도 월에 따라 마지막 날 리턴
// 예: lastDay(200711) = > 2007년도 11월의 마지막 날: 30
//***************************************************
function lastDay(sDate)
{ try{
	if (sDate == "" || sDate == null) // sDate 값이 없다면 오늘 날짜
    		sDate = getDate().substring(0,6) ;
    	
	var curYear = parseInt(sDate.substring(0, 4));
	var curMon = parseInt(sDate.substring(4, 6)) + 1 ;
	if (curMon > 12) {
		curYear++ ;
		curMon = "01" ;
	}
	curMon = addZero(curMon, 2);
	sDate = curYear + curMon + "01" ;
	return(prevDay(sDate).substring(6,8));
} catch(e) { model.alert(getFormID() + " => function => lastDay => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 정해진 날짜의 이전달 날짜 얻기
// 예: prevMonth("20080116") => 리턴값: 20080216
//	 prevMonth("20080131") => 리턴값: 20080229
//***************************************************
function prevMonth(sDate)
{
  	var y =parseInt(sDate.substring(0, 4)); 
	var m = sDate.substring(4,6); 
	if (m < 10)
		m =  sDate.substring(5,6) ;	
	var d = sDate.substring(6,8);  

	var curLastD= lastDay(y+ m);  
	
	m = new String(parseInt(m)-1);
	
	if (m == 0) {
		y = new String(y-1);
		m= "12" ;
	}else {			
		if (m < 10 )	
			m = "0" + m;
	}
	var mm = m;
	if (m < 10)
		mm = m.replace("0", "");		
	var nextLastD = lastDay(y+mm); 
	
	if (parseInt(d) > parseInt(nextLastD))
		var ymd = y+m+nextLastD;
	else
		var ymd = y+m+d;
						
	return (ymd);			
}	

//***************************************************
// ComMate: 정해진 날짜의 다음달 날짜 얻기
// 예: nextMonth("20080116") => 리턴값: 20071216
//	 nextMonth("20080331") => 리턴값: 20080229
//***************************************************
function nextMonth(sDate){

	var y =parseInt(sDate.substring(0, 4)); 
	var m = sDate.substring(4,6); 
	if (m < 10)
		m =  sDate.substring(5,6) ;	
	var d = sDate.substring(6,8);  

	var curLastD= lastDay(y+ m);  
	
	m = new String(parseInt(m)+1);
	
	if (m > 12) {
		y = new String(y+1);
		m= "01" ;
	}else {			
		if (m < 10 )	
			m = "0" + m;
	}	
					
	var mm = m;
	if (m < 10)
		mm = m.replace("0", "");				
	var nextLastD= lastDay(y+mm); 
		
	if (parseInt(d) > parseInt(nextLastD))
		var ymd = y+m+nextLastD;
	else
		var ymd= y+m+d;
					
	return (ymd);	
}	

//***************************************************
// ComMate: 지정한 날자에 따라 요일 구하기
// 예: getWeek("20071213") => 결과값: 목
//***************************************************
function getWeek(sDate) 
{ try{
	var weekDate = new Date();
	if (sDate != null && sDate != "") {
		weekDate = new Date(sDate.substring(4,6) + "-" + sDate.substring(6,8) + "-" + sDate.substring(0,4)) ;
	}
    	var index = weekDate.getDay(); //일요일=0,월요일=1,...,토요일=6
    	var week = new Array('일','월','화','수','목','금','토');
    	return week[index];
} catch(e) { model.alert(getFormID() + " => function => getWeek => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 숫자 반올림 처리 ( 소수점 아래 자리수 지정 가능 )
// 예: mathRound(65.67, 1) => 결과값 65.7
//***************************************************
function mathRound(num, length) 
{ try{
	return parseFloat(num).toFixed(length);
} catch(e) { model.alert(getFormID() + " => function => mathRound => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 일반 메시지 확인창 띄우기
// 모든 alert 함수는 alertBox 로 대체할 것
//***************************************************
function alertBox(msg)
{ try{
	// 언어 변환
	msg = msg + "" ; // returnSubmit(msg) ;
	
	// msg = replaceAll(msg, "\\n", "     \n") ;
