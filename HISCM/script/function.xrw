//***************************************************
// ComMate: alertBox 언어 변환 submit 후 리턴
//***************************************************
function returnSubmit(msg) 
{ try{
	var pageLang = model.getValue("/root/cmdMdbUserInfo/pageLang");
	if (pageLang != "LANGKS") {
		msg = replaceAll(msg, "\\n", "▤") ;
	
		model.setValue("/root/cmdSendLang/pageLang", pageLang);
		model.setValue("/root/cmdSendLang/alertStr", msg);
		model.setValue("/root/cmdSendLang/gridStr", "");
		model.setValue("/root/cmdSendLang/capStr", "");
		model.setValue("/root/cmdSendLang/comboStr", "");
		model.setValue("/root/cmdSendLang/btnStr", "");
		
		submit("commonChangeLang","/root/cmdSendLang");
		msg = model.getValue("/root/msgBuff/changeLang/alertStr");
		msg = replaceAll(msg, "▤", "     \n");
		msg = replaceAll(msg, "null", "");
		return msg + "     " ;
	} else {
		msg = replaceAll(msg, "\\n", "     \n") ;
		return msg + "     " ;
	}
} catch(e) { model.alert(getFormID() + " => function => returnSubmit => " + e, "ComMate DEBUG"); return false; }}
//***************************************************
// ComMate: 문자열 변환 함수 
// 예: replaceAll("a0a0a0a0", "a", "b") => b0b0b0b
//***************************************************
function replaceAll(strData, str1, str2)
{ try{
  return  strData.replace(eval("/" + str1 + "/gi"), str2);
} catch(e) { model.alert(getFormID() + " => function => replaceAll => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 숫자 뒤에 붙는 문자 제거 숫자만 반환
// 예: replacePx("650pxpx", "pxpx") => 650 ( 두번째 인자 기본값 "px" )
//***************************************************
function removePx(srcNum, splitStr)
{ try{
	if( splitStr ){
		if(  !isNumber(srcNum)  )   srcNum = srcNum.replace(splitStr, "");
	}else{
		if(  !isNumber(srcNum)  )   srcNum = srcNum.replace("px", "");
	}
	return parseInt(srcNum, 10);
} catch(e) { model.alert(getFormID() + " => function => removePx => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 문자열 바이트수 구하기 한,중,일 2 byte 로 계산
// 예: getStrByte("한-a3") => 결과값: 5
//***************************************************
 function getStrByte(str)
 { try{
       var strByte = 0;
       if ( str == null ) return 0;
       for(var i=0; i<str.length; i++){
          var curStr = escape(str.charAt(i));
          if ( curStr.length == 1 ) strByte ++;
          else if ( curStr.indexOf("%u") != -1 ) strByte += 2;
          else if ( curStr.indexOf("%") != -1 ) strByte += curStr.length/3;
       }
       return strByte;
} catch(e) { model.alert(getFormID() + " => function => getStrByte => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 숫자인지 확인
//***************************************************
function isNum(str)
{ try{
    str = str.toString();
    str = str.replace(".", "");
    for(var i=0; i < str.length; i++){
    	var curStr = str.charAt(i) ;
	if ( curStr < '0' || curStr > '9') {
		return false;
	}
    }
    return true;
} catch(e) { model.alert(getFormID() + " => function => isNum => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 입력값이 E-mail 형식인지 확인
//***************************************************
//function isValidEmail(input) {
////    var format = /^(\S+)@(\S+)\.([A-Za-z]+)$/;
//    var format = /^((\w|[\-\.])+)@((\w|[\-\.])+)\.([A-Za-z]+)$/;
//    return isValidFormat(input,format);
//}
//***************************************************
// ComMate: 한글인지 확인
//***************************************************
function isKor(str)
{ try{
    str = str.toString();
     for(var i=0; i < str.length; i++) {
	var curStr = escape(str.charAt(i));
	if ( curStr.indexOf("%u") == -1 ) {
		 return false;
	}
    }
    return true;  
} catch(e) { model.alert(getFormID() + " => function => isKor => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 영문인지 확인
//***************************************************
function isEng(str)
{ try{
    str = str.toString();
    for(var i=0; i < str.length; i++){
    	var curStr = str.charAt(i) ;
	if (!((curStr >='a' && curStr <= 'z') || (curStr >= 'A' && curStr <= 'Z'))){
		return false;
	}
    }
    return true;
} catch(e) { model.alert(getFormID() + " => function => isEng => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: RGB값을 16진수로 변환.
//***************************************************
function RGBtoHex(R,G,B)
{ try{
    return "#" + toHex(R) + toHex(G) + toHex(B);
} catch(e) { model.alert(getFormID() + " => function => RGBtoHex => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 10진수 값을 16진수로 변환.
//***************************************************
function toHex(Num)
{ try{

    if(isNaN(Num) || Num == null || Num == 0 ) return "00";
    Num = parseInt(Num, 10);

    return "0123456789ABCDEF".charAt((Num-Num%16)/16)
    		+ "0123456789ABCDEF".charAt(Num%16);

} catch(e) { model.alert(getFormID() + " => function => toHex => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 디버깅 함수
//***************************************************
function debug(msg1, msg2, msg3, msg4, msg5, msg6, msg7, msg8, msg9, msg10)
{ try{
	alert(msg1 +", "+msg2+", "+msg3+", "+msg4+", "+msg5+", "+msg6+", "+msg7+", "+msg8+", "+msg9+", "+msg10) ;
} catch(e) { model.alert(getFormID() + " => function => debug => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 폴더 생성 (존재안할때만) 
//***************************************************
function createFolder(fldr) 
{ try{
	var fso = new ActiveXObject("Scripting.FileSystemObject");
	   
	if(!(fso.FolderExists(fldr))) {
		f = fso.GetFolder(fldr.substring(0, fldr.lastIndexOf("\\")+1));
		fc = f.SubFolders;
		nf = fc.Add(fldr.substring(fldr.lastIndexOf("\\")+1));
	}
} catch(e) { model.alert(getFormID() + " => function => createFolder => " + e, "ComMate DEBUG"); return false; }}

//**********************************************************
// ComMate: 지정 폴더 하위 파일 전부 지우기 ( 클라이언트 폴더 )
// isDeleteFolder "yes"일 경우 폴더 지우기, 디폴트 남김
// 리턴값: 지우지 못한 파일 갯수
//**********************************************************
function deleteFolder(folderspec, isDeleteFolder)
{ try{ 
       var fucObj =  arguments.callee; 
	var notRemoveCount = 0 ;
	var fso = new ActiveXObject("Scripting.FileSystemObject");
	var folderObj ; 
	try {
		folderObj = fso.GetFolder(folderspec);
		var fileList = new Enumerator(folderObj.files);  // 하위 폴더 리스트 얻기
		for (; !fileList.atEnd(); fileList.moveNext()) {
			var curFile = fileList.item();
			try {
				fso.DeleteFile(folderspec + "\\" + curFile.name) ;
			} catch(e) {
				notRemoveCount ++ ; // 하위 폴더 지우기 실패시 지우기 실패한  카운터 올리기
//				alert("열려져 있는 "+ curFile.name +" 파일을 닫아주십시오." );
			}
		}
	} catch(e) {
		//alert(folderspec + " 는(은) 존재하지 않는 폴더입니다. ") ;
	}
	if (notRemoveCount == 0 && isDeleteFolder == "yes") { // 하위 파일을 전부 삭제 했을 경우 폴더 지우기
		try { fso.DeleteFolder(folderspec); } catch(e) {}
	}
	return notRemoveCount ; // 지우기 실패한 파일 갯수 리턴
} catch(e) { getDebug(); return false; }}

//**********************************************************
// ComMate: 파일보기
//**********************************************************
function viewFile(control) 
{ try{ 

	var obj = document.controls(control) ;
	if (obj.elementName == "xforms:datagrid") {
		var orifilelist = model.getValue("/root/msgFiles/orifilelist");
		var oriSplit = orifilelist.split("▤");
		for(var i=0 ; i<oriSplit.length ; i++){ 
			document.all(control).addRow();
			document.all(control).valueMatrix(datagrid1.rows-1, 0) = oriSplit[i];       
		}      
		document.all(control).rebuild();
	}else if (obj.elementName == "xforms:img") {  
		var savefile = model.getValue("/root/msgFiles/savefilelist"); 
		var address = model.getValue("/root/msgFiles/address");     
		document.all(control).src = address + savefile;		     
		document.all(control).refresh();
	}
	 
} catch(e) { model.alert(getFormID() + " => function => viewFile => " + e, "ComMate DEBUG"); return false; }}

//**********************************************************
// ComMate: 파일다운로드 
//**********************************************************
function downFile(control, selFile) 
{ try{ 
	var obj = document.controls(control) ;
	if (obj.elementName == "xforms:datagrid") {
		var savefilelist = model.getValue("/root/msgFiles/savefilelist");
		var saveSplit = savefilelist.split("▤");	 
		if (selFile > 0) {      
			var address = model.getValue("/root/msgFiles/address"); 
			var fileNames = saveSplit[selFile-1].replace(/\\/g, "/");
			var savePath = address + fileNames;
			//alert(savePath);
			var nodeSet = document.all(control).attribute("nodeset");       
			var node = instance1.selectSingleNode(nodeSet); 
			var nodeList = node.childNodes;
			var tmp, downName = "";
			while( (tmp = nodeList.nextNode() ) != null ) {
				downName = tmp.tagName ;   
			}
			
			var winWidth = htmlwindow.screen.width; 
			var winHeight = htmlwindow.screen.height;
			window.load("../xrwHelp/doSaveFile.xrw", "modal", "doSaveFile", "min:hidden;max:hidden;resize:false;left:"+parseInt((winWidth-250)/2)+"px;top:"+parseInt((winHeight-150)/2)+"px;width:240px;height:120px;");
			var doSaveFile = model.getValue("/root/doSaveFile");
			if (doSaveFile == "save") {
				var file = window.fileDialog("save", "", "", model.getValue(nodeSet  + "[" + selFile + "]/" + downName));
				if (file != "") model.download(savePath, file, true);	
			} else if (doSaveFile == "open") {
				createFolder("C:\\ComMate\\temp");
				model.download(savePath, "C:\\ComMate\\temp\\"+model.getValue(nodeSet  + "[" + selFile + "]/" + downName), true);
				window.exec(model.getValue(nodeSet  + "[" + selFile + "]/" + downName), "", "C:\\ComMate\\temp\\") ;
			}
		}
	}
} catch(e) { model.alert(getFormID() + " => function => downFile => " + e, "ComMate DEBUG"); return false; }} 
	
//**********************************************************
// ComMate: 업로드 컨트롤 셋팅
//**********************************************************
function uploadReset()
{ try{

 var obj = document.controls ;
 for (var i=0; i<obj.length; i++) {
  if (obj.item(i).elementName == "xforms:upload") {
   model.resetInstanceNode("/root/sendFiles"); // sendFiles 노드 리셋하기
   var gridNode = obj.item(i).attribute("nodeset").split("/item")[0] ; 
   var itemLength = instance1.selectNodes(gridNode + "/item").length ;
   for (var j=1; j <= itemLength; j++) {
    // sendFiles 밑에 파일 숫자만큼 노드 추가하고 파일 이름 설정하기
    var fileList = instance1.selectSingleNode(gridNode + "/item["+j+"]").childNodes ;
    var fileNode = fileList.nextNode(); 
    var fileName = model.getValue(fileNode);
    model.makeValue("/root/sendFiles/file" + j, fileName);
    
    // 파일 숫자만큼 upload 컨트롤 생성하고 sendFiles 와 연결하기
    body.createChild("xforms:upload", "id:upload"+j);
    document.all("upload"+j).attribute("style") = "left:100; top:100px; width:50px; height:50px;";
    document.all("upload"+j).attribute("nodeset") = "/root/sendFiles/file" + j;
    document.all("upload"+j).refresh();        
   }
   // 초기 upload 컨트롤 삭제하기
   document.all(obj.item(i).attribute("id")).parent.removeChild(obj.item(i).attribute("id")); 
   break;
  } 
 }
} catch(e) {  return false; }}
			]]>
		</script>
