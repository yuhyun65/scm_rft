function getFormID() 
{ try{
	var docSplit = document.url.split("/");
	var formID = docSplit[docSplit.length-1].replace("$", "") ;
	formID = formID.substring(0, formID.length-4);
	// 게시판이라면 boardInfo 의 formID 로 교체
	if (formID.substring(0, 9) == "boardA001" || formID.substring(0, 10) == "noticeA001") {
		formID = model.getValue("/root/boardInfo/formID");
	}
	return formID ;
} catch(e) { model.alert(getFormID() + " => function => getFormID => " + e, "ComMate DEBUG"); return false; }}
