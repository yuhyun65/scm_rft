} catch(e) { model.alert(getFormID() + " => function => errAlert => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 예/아니오 창 띄우기
//***************************************************
function yesAlert(msg)
{ try{
	// 언어 변환
