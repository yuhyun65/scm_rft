<?xml version="1.0" encoding="UTF-8"?>
<xhtml:html xmlns:xhtml="http://www.w3.org/1999/xhtml" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns="http://www.w3.org/2002/01/xforms" xmlns:ev="http://www.w3.org/2001/xml-events">
	<xhtml:head>
		<xhtml:title>::: MATE-ERP :::</xhtml:title>
		<model id="model1">
			<instance id="instance1">
				<root xmlns="">
				</root>
			</instance>
		</model>
		<script type="javascript">
			<![CDATA[
//==================================================
// (주) 컴퓨터메이트 - 공통 함수 선언 
//***************************************************
// ComMate: 공통 변수 선언
//***************************************************
var rootURL = (htmlwindow.location + "").split("/xrwCom")[0] ;
var sendBuff = "/root/sendBuff";
var msgBuff = "/root/msgBuff";

//***************************************************
// ComMate: 모든 서브밋 정보는 반드시 이 함수를 통해서 서브밋
//***************************************************	
function submit(spName, workGB)
{ try{
	
	if (workGB != "" && workGB != null)
	{
		model.setValue("/root/sendBuff/spName", spName);
		model.setValue("/root/sendBuff/workGB", workGB);
	} else {
		model.setValue("/root/sendBuff/queryString", spName);
	}
	
	var objSubmit = document.all("submit");
	objSubmit.attribute("action") = rootURL + "/servlet/Common.Controller" ;
	objSubmit.attribute("ref") = sendBuff;
	objSubmit.attribute("resultref") = msgBuff ;

	objSubmit.attribute("encoding") = "utf-8" ;
	objSubmit.attribute("method") = "post" ;
	objSubmit.attribute("mediatype") = "application/x-www-form-urlencoded" ;

	//진행창 보이기
	body.disabled = true;
	setProgress(true);
	
	model.send("submit", false);
	
	try {
		var errMsg = model.getValue("/root/msgBuff/data/GetDataErr");
		model.setValue("/root/msgBuff/data/GetDataErr", replaceAll(errMsg, "at ", "\r\n\tat "));
	} catch(e) {}
	
	//진행창 숨기기
	setProgress(false);
	body.disabled = false;

	return true;
	
} catch(e) { model.alert(getFormID() + " => function => submit => " + e, "ComMate DEBUG"); return false; }}
//***************************************************
// ComMate: 파일 업로드 단독 사용
//***************************************************
function sendBuffInit()
{ try{
	model.copyNode("/root/sendBuff", "/root/cmdTemp");
	instance1.selectSingleNode("/root/sendBuff").appendChild(instance1.createElement("argList"));
	instance1.selectSingleNode("/root/sendBuff").appendChild(instance1.createElement("spName"));
	instance1.selectSingleNode("/root/sendBuff").appendChild(instance1.createElement("workGB"));
	instance1.selectSingleNode("/root/sendBuff").appendChild(instance1.createElement("queryString"));
} catch(e) { model.alert(getFormID() + " => function => sendBuffSet => " + e, "ComMate DEBUG"); return false; }}
//***************************************************
// ComMate: 파일 업로드 단독 사용
//***************************************************
function sendBuffAdd(argName, argValue)
{ try{
	var argList = model.getValue("/root/sendBuff/argList");
	if (argList == "") {
		model.setValue("/root/sendBuff/argList", argName);
	} else {
		model.setValue("/root/sendBuff/argList", argList + "," + argName);
	}

	instance1.selectSingleNode("/root/sendBuff").appendChild(instance1.createElement(argName));
	model.setValue("/root/sendBuff/" + argName, argValue);
	
} catch(e) { model.alert(getFormID() + " => function => sendBuffAdd => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 파일 업로드 단독 사용
//***************************************************
function upload(tableName, type, fileUID)
{ try{
		var objUpload = document.all("submit");

		objUpload.attribute("action") = rootURL + "/servlet/Common.Controller" ;
		
		model.setValue("/root/cmdUpload/tableName", tableName); // 파일을 보유하고 있는 테이블
		model.setValue("/root/cmdUpload/type", type); 
		model.setValue("/root/cmdUpload/fileUID", fileUID);
		model.setValue("/root/cmdUpload/userName", getUserName());
		model.setValue("/root/cmdUpload/upload", "Y");
		
		if (type == "get" || type == "del") {
			model.setValue("/root/sendFiles", "-");
		}

		objUpload.attribute("ref") =  "/root/sendFiles,/root/cmdUpload,/root/cmdMdbUserInfo" ; 
		objUpload.attribute("resultref") = "/root/msgBuff" ;

		objUpload.attribute("encoding") = "utf-8" ;

		objUpload.attribute("method") = "form-data-post" ;
		objUpload.attribute("mediatype") = "multipart/form-data" ;

		//진행창 보이기
		body.disabled = true;
		var printStr = "※ 파일 업로드중입니다. 잠시만 기다려주십시오." ;
		setProgress(true, printStr);
		
		model.send("submit");
				
		model.copyNode("/root/msgFiles", "/root/msgBuff/msgFiles");	

		//진행창 숨기기
		setProgress(false);
		body.disabled = false;
		
		return true;
		
} catch(e) { model.alert(getFormID() + " => function => upload => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 간단한 암호화 처리
//***************************************************
function enCode(str, key)
{ try{
	// " ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789,.-:;/()[]{}"
	var keyCode = parseInt(key);
	if (keyCode == 0) keyCode = 10 ;
	
	var codeList = "sEeGhSA;/nTwQ3xUkF(gK]l8.fVo N[b2qD:rM-udCBcYpO)yP}1Lai5v9,Hz0jmR6Z7W4IJ{X" ;
	var returnStr = "" ;
	for (var i=0; i<str.length; i++) {
	   var index = codeList.indexOf(str.charAt(i)) ;
	   if (index == -1) { // 리스트에 없다면 원래 문자 추가
	   	returnStr += str.charAt(i) ; 
	   } else {  // 리스트에 있다면 해당 문자 추가
	   	index += keyCode ;
	   	while (index >= codeList.length) {
	   		index = index - codeList.length ; 
	   	}
	   	returnStr += codeList.charAt(index); 
	   }
	}
	return returnStr;
} catch(e) { model.alert(getFormID() + " => function => enCode => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 복호화
//***************************************************
function deCode(str, key)
{ try{
	
	var keyCode = parseInt(key);
	if (keyCode == 0) keyCode = 10 ;
	
	var codeList = "sEeGhSA;/nTwQ3xUkF(gK]l8.fVo N[b2qD:rM-udCBcYpO)yP}1Lai5v9,Hz0jmR6Z7W4IJ{X" ;
	var returnStr = "" ;
	for (var i=0; i<str.length; i++) {
	   var index = codeList.indexOf(str.charAt(i)) ;
	   if (index == -1) { // 리스트에 없다면 원래 문자 추가
	   	returnStr += str.charAt(i) ; 
	   } else {  // 리스트에 있다면 해당 문자 추가
	   	index -= keyCode ;
	   	while (index < 0) {
	   		index = index + codeList.length ; 
	   	}
	   	returnStr += codeList.charAt(index); 
	   }
	}
	return returnStr;
} catch(e) { model.alert(getFormID() + " => function => deCode => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 진행중 창 설정
//***************************************************
function setProgress(showFlag, str)
{ try{
	var printStr = "※ 진행중입니다. 잠시만 기다려주십시오." ;
	if (str != null || str != "") { // 출력 문자열 지정했을 경우
		printStr = str ;
	}
	try {
		progress.visible = showFlag;
	} catch(e) {
		try {
			parent.document.all("progress").text = printStr;
			parent.document.all("progress").visible = showFlag;
		}catch(e) {
			try {
				parent.parent.document.all("progress").text = printStr;
				parent.parent.document.all("progress").visible = showFlag;
			}catch(e) {
			}
		}
	}

} catch(e) { model.alert(getFormID() + " => function => setProgress => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 마우스 팝업 디자인
//***************************************************
function mousePopup(gridID)
{ try{
	 if (document.all(gridID).mouserow >= document.all(gridID).fixedrows && document.all(gridID).selectionMode == "free") //그리드에서 데이타영역만
	{	
		model.property("gridID") = gridID;
		window.setPopupMenu(true, "/root/cmdMousePopup/menu/item", "name", "func", false);
		//사용자지정팝업메뉴설정
	} else if (document.all(gridID).mouserow >= document.all(gridID).fixedrows && document.all(gridID).selectionMode != "free"){
		var viewSource = model.getValue("/root/setValue/viewSource") ;
		if (viewSource == "N") {
			window.showPopupMenu(false);
		}
		window.setPopupMenu(false);
	}else if (document.all(gridID).mouserow == 0 ){
		 if(event.button == 1) {
			try {
				var colRef = model.getValue("/root/cmdSubtotalColList/"+gridID);	//해당 그리드정보 있는지 체크
				var colList = colRef.split(",");
				for(var i = 0; i < colList.length; i++) {
					document.all(gridID).subtotal("clear",-1,document.all(gridID).colRef(colList[i]));
				}
				
			}catch(e) {}
		}
		else {
		 	var col = document.all(gridID).mousecol;
		 	model.property("gridID") = gridID;
			model.property("colStr") = document.all(gridID).colAttribute(col,"ref");
		 	window.setPopupMenu(true, "/root/cmdMousePopup/subtotal/item", "name", "func", false);
		 	//alert("마지막");
		}
 	}
} catch(e) { model.alert(getFormID() + " => function => mousePopup => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: help창 띄워주는 함수
//***************************************************
function helpPop(popDataPath)
{ try{
	var ctrlLeft;
	var ctrlTop;
	var parentObj;
	try { // 일반 컨트롤일 경우..
		ctrlLeft = parseInt(document.all(event.target).attribute("left"));
		ctrlTop = parseInt(document.all(event.target).attribute("top"));
		parentObj = document.all(event.target).parent ;
	}catch(e) {		//datagrid일 경우..
		try {
			ctrlLeft = parseInt(document.all(event.ptarget.parent.attribute("id")).attribute("left"));
			ctrlTop = parseInt(document.all(event.ptarget.parent.attribute("id")).attribute("top"));
			parentObj = document.all(event.ptarget.parent.attribute("id")).parent ;
		}catch (e) {	//수정한것....
			gridID = model.property("gridID");
			ctrlLeft = parseInt(document.all(gridID).attribute("left"));
			ctrlTop = parseInt(document.all(gridID).attribute("top"));
			parentObj = document.all(gridID).parent ;
		}
	}
	
	while(parentObj.elementName != "xhtml:body") {
		ctrlLeft += parseInt(parentObj.attribute("left"));
		ctrlTop += parseInt(parentObj.attribute("top"));
		parentObj = parentObj.parent ;
	}
	
	try {
		ctrlLeft += parseInt(parent.document.all("iviewerPrevMain").attribute("left"));
		ctrlTop += parseInt(parent.document.all("iviewerPrevMain").attribute("top"));

		ctrlLeft += parseInt(parent.document.all("switchMain").attribute("left"));
		ctrlTop += parseInt(parent.document.all("switchMain").attribute("top"));
	}catch(e) {}
	
	var colWidth = model.getValue("/root/cmdHelpPopData/colWidth").split(","); 
	var popupSizeX = 100;
	var popupSizeY = parseInt(model.getValue("/root/cmdHelpPopData/winHeight"));
	for(var i = 0; i < colWidth.length; i++) {
		popupSizeX += parseInt(colWidth[i]);
	}
	var searchData = "" ;
	
	try{
		// 일반 텍스트 박스에서 help 창 띄울 경우...
		 model.setValue("/root/cmdHelpPopData/searchData", document.all(event.target).currentText);
	}catch(e){
		// 그리드에서 help창 띄울 경우...
 		try{
 			// 데이터 그리드 셀의 값 얻어 오기
			var target = event.ptarget.parent.attribute("id");
			var row = document.all(target).row;
			var col = document.all(target).col;
			searchData = document.all(target).valueMatrix(row,col);
			var colWidth = document.all(target).attribute("colwidth").split(",");	//그리드일때 left위치 구할때

			for( var i = 0; i < col; i++) {
				ctrlLeft += parseInt(colWidth[i]);
			}
			
			var dataHeight = document.all(target).attribute("dataheight");		//그리드일때 top위치 구할때
			ctrlTop += parseInt(dataHeight) * parseInt((row+1));
			model.setValue("/root/cmdHelpPopData/searchData",searchData);
		}catch(e){}
	}

	if(popDataPath != "" && popDataPath != null) {
		model.copyNode("/root/cmdHelpPopData/popData", popDataPath);
	}
	var windowX = parent.window.width;
	var windowY = parent.window.height;
	if((ctrlTop+popupSizeY) > windowY) {
		var tempTop = (ctrlTop+popupSizeY) - windowY;
		ctrlTop = ctrlTop - tempTop;
	}

	if(((ctrlLeft-(popupSizeX/2))+popupSizeX) > windowX) {
		var tempLeft = (ctrlLeft-(popupSizeX/2)+popupSizeX) - windowX;
		ctrlLeft = (ctrlLeft-(popupSizeX/2)) - tempLeft;
	} else {
		ctrlLeft = ctrlLeft-(popupSizeX/2);
	}

	if(ctrlLeft < 0 ) {
		ctrlLeft = 0;
	}
	
	if(ctrlTop < 0 ) {
		ctrlTop = 0;
	}

	window.load("../xrwHelp/helpCmd.xrw","modal","", "left:"+ctrlLeft+"px; top:"
	+ctrlTop+"px; width:"+popupSizeX+"px; height:"+popupSizeY+"px; max:hidden;","/root/cmdHelpPopData","/root/cmdHelpPopData");
	
} catch(e) { model.alert(getFormID() + " => function => helpPop => " + e, "ComMate DEBUG"); return false; }}
//***************************************************
// ComMate: help창 속성 설정
//***************************************************
function setHelpPop(attr, value)
{ try {
	model.setValue("/root/cmdHelpPopData/"+attr, value);
} catch(e) { model.alert(getFormID() + " => function => setHelpPop => " + e, "ComMate DEBUG"); return false; }}
//***************************************************
// ComMate: 서브 토탈 함수
//***************************************************
function gridSubtotal(gridID, col)
{ try{
	for (var i = 1; i< document.all(gridID).cols ; i++) {
		var curColRef = document.all(gridID).colAttribute(i,"ref") ;
		if (col.indexOf(curColRef) == -1) {
			model.property("colStr") = curColRef ;
			break;
		}
	}	
	model.property("gridID") = gridID ;
	var colValue = "";
	try {
		colValue = model.getValue("/root/cmdSubtotalColList/"+gridID);
	}catch(e) {}
	
	if(colValue == "") {
		model.makeNode("/root/cmdSubtotalColList/"+gridID);
		model.setValue("/root/cmdSubtotalColList/"+gridID,","+col);
	} else {
		if(colValue.search(col) == -1) {
			col = colValue + "," + col;
			model.setValue("/root/cmdSubtotalColList/"+gridID,col);
		}
	}
} catch(e) { model.alert(getFormID() + " => function => gridSubtotal => " + e, "ComMate DEBUG"); return false; }}

function ascSubtotal() 
{ try{
//	setSubtotal();
	try {
		var gridID = model.property("gridID");
		var colRef = model.getValue("/root/cmdSubtotalColList/"+gridID);	//해당 그리드정보 있는지 체크
		getSubtotal(colRef, "asc");
	}catch(e) {
		alerBox("소계할 항목을 추가 하십시오");
	}
//	var colRef = model.property("gridCol");
//	getSubtotal(colRef, "asc");
} catch(e) { model.alert(getFormID() + " => function => ascSubtotal => " + e, "ComMate DEBUG"); return false; }}

function descSubtotal() 
{ try{
	try {
		var gridID = model.property("gridID");
		var colRef = model.getValue("/root/cmdSubtotalColList/"+gridID);	//해당 그리드정보 있는지 체크
		getSubtotal(colRef, "asc");
	}catch(e) {
		alerBox("소계할 항목을 추가 하십시오");
	}
//	setSubtotal();
//	var colRef = model.property("gridCol");
	getSubtotal(colRef, "desc");
} catch(e) { model.alert(getFormID() + " => function => descSubtotal => " + e, "ComMate DEBUG"); return false; }}

function getSubtotal(colRef, type) 
{ try{
	 var grid = document.all(model.property("gridID"));
	 var colStr = model.property("colStr");
	 var col = grid.colRef(colStr);
	 var colList = colRef.split(",");
	 var index = grid.colRef(colStr);
	 
	 for(var i = 1; i < colList.length; i++) { // 서브토탈 없애기
	 	if(grid.colRef(colStr) == grid.colRef(colList[i])) {
	 		for(var j = 1; j < grid.cols; j++) {
	 			if(colRef.indexOf(grid.colAttribute(j,"ref")) == -1) {
	 				index = j;
	 				break;	 				
	 			}
	 		}
	 	}
	  	grid.subtotal("clear",-1,grid.colRef(colList[i]));
	 }
	grid.colSort(col) = type; // 오른차순 내림차순 타입 지정
	grid.sort(1,1, grid.rows-1, grid.cols-1) = "usersort";  // 소팅
	grid.refresh(); 
	grid.colSort(col) = "none";
	
	// grid.gridToInstance(); // 소팅 결과 인스턴스로 복사
	
	grid.subtotalposition= "after";
	
	// 그룹: grid.colRef(col)   소계할 Col : grid.colRef(colList[1])   소계 문자열 표시 위치: grid.colRef(col)
	grid.subtotal("sum", grid.colRef(colStr), grid.colRef(colList[1]), "#,###", "color:#660000;font-weight:boldl;background-color:#cccccc", index, "소계");
	grid.subtotal("sum", -1, grid.colRef(colList[1]), "#,###", "color:#660000;font-weight:bold;background-color:#b59baa" ,index,"총계");
	 for(var i = 2; i < colList.length; i++) {
		grid.subtotal("sum", grid.colRef(colStr), grid.colRef(colList[i]), "#,###", "", "", "");
		grid.subtotal("sum", -1, grid.colRef(colList[i]), "#,###", "", "", "");
	 }
 	 initSetGrid(); // MDB 정보를 통한 그리드 초기화
} catch(e) { model.alert(getFormID() + " => function => getSubtotal => " + e, "ComMate DEBUG"); return false; }}

function addSubtotal() 
{ try{
	var gridID = model.property("gridID");
	var node = "";
	try {
		node = instance1.selectSingleNode("/root/cmdSubtotalColList/"+gridID);	//해당 그리드정보 있는지 체크
		var col = model.getValue("/root/cmdSubtotalColList/"+gridID);	//해당 그리드 정보 가져오기
		var colList = col.split(",");
		for(var i = 1; i < colList.length; i++) {
			if( colList[i] == model.property("colStr") ){ //값이 있다면
				return;
			} 
		}
		// 값이 없다면 추가
		model.setValue("/root/cmdSubtotalColList/"+gridID, col+","+model.property("colStr") );
	}catch(e) {
		//해당그리드 정보가 없다면 노드 생성후 초기값 추가
 		model.makeNode("/root/cmdSubtotalColList/"+gridID);
		model.setValue("/root/cmdSubtotalColList/"+gridID,","+model.property("colStr") );
	}
	ascSubtotal();
} catch(e) { model.alert(getFormID() + " => function => addSubtotal => " + e, "ComMate DEBUG"); return false; }}


function delSubtotal() 
{ try{
	var gridID = model.property("gridID");
	var node = "";
	try {
		node = instance1.selectSingleNode("/root/cmdSubtotalColList/"+gridID);	//해당 그리드정보 있는지 체크
		var col = model.getValue("/root/cmdSubtotalColList/"+gridID);	//해당 그리드 정보 가져오기
		var colList = col.split(",");
		var newColList = "";
		for(var i = 1; i < colList.length; i++) {
			if( colList[i] != model.property("colStr") ){ //값이 있다면
				newColList += "," + colList[i];
			}
		}
		model.setValue("/root/cmdSubtotalColList/"+gridID,newColList);
	}catch(e) {}
	if(newColList != ""){
		ascSubtotal();
	}else {
		var colRef = model.getValue("/root/cmdSubtotalColList/"+gridID);	//해당 그리드정보 있는지 체크
		var colList = colRef.split(",");
		for(var i = 0; i < colList.length; i++) {
			document.all(gridID).subtotal("clear",-1,document.all(gridID).colRef(colList[i]));
		}
	}
} catch(e) { model.alert(getFormID() + " => function => delSubtotal => " + e, "ComMate DEBUG"); return false; }}

function userSort() // 수정
{ try{
	try {
		var gridID = model.property("gridID");
		var gridCaption = document.all(gridID).attribute("caption");
		var captionList = gridCaption.split("^");
		var cols = document.all(gridID).cols;
		gridCaption = "";
		var colIndex = "";
		for( var i = 0; i < cols ; i++) {
			if(document.all(gridID).attribute("rowheader") != "") {
				if(i > 0) {
					if(document.all(gridID).colAttribute(i,"ref") != "" && captionList[i-1] != "" && document.all(gridID).colAttribute(i,"visibility") != "hidden" ) {
						colIndex += "," + i;
						gridCaption += "," + captionList[i-1];
					}
				}
			} else {
				if(document.all(gridID).colAttribute(i,"ref") != "" && captionList[i] != "" && document.all(gridID).colAttribute(i,"visibility") != "hidden" ) {
					colIndex += "," + i;
					gridCaption += "," + captionList[i];
				}
			}
		}
		model.setValue("/root/cmdSortPopData/colIndex",colIndex);
		model.setValue("/root/cmdSortPopData/gridCaption",gridCaption);
		var xPath1 = "/root/cmdSortPopData/gridSort";
		var xPath2 = "/root/cmdSortPopData/isAsc" ;
		var popDataPath = "/root/cmdSortPopData";			
		helpGridPop("helpSort",xPath1,xPath2,"","","",popDataPath);  //Help 창을 띄운다.
		var gridSort = model.getValue("/root/cmdSortPopData/gridSort");
		var isAsc = model.getValue("/root/cmdSortPopData/isAsc");
		var SortList = gridSort.split(",");
		var AscList = isAsc.split(",");
		for(var i = 1; i < SortList.length; i++) {
			if(AscList[i] == 1) {
				document.all(gridID).colSort(SortList[i]) = "asc";
			} else if (AscList[i] == 2){
				document.all(gridID).colSort(SortList[i]) = "desc";
			}
		}
		document.all(gridID).sort(1,1, document.all(gridID).rows-1, document.all(gridID).cols-1) = "usersort";
		var cols = document.all(gridID).cols;
		for(var i = 0; i < cols; i++) {
			document.all(gridID).colSort(i) = "none";
		}
	}catch(e) {
		alerBox("그리드가 아닙니다.");
	}
} catch(e) { model.alert(getFormID() + " => function => userSort => " + e, "ComMate DEBUG"); return false; }}


function gridHidden() // 그리드 컬럼 히든 함수
{ try{
	try {
		var gridID = model.property("gridID");
		var gridCaption = document.all(gridID).attribute("caption");
		var captionList = gridCaption.split("^");
		var cols = document.all(gridID).cols;
		gridCaption = "";
		var colIndex = "";
		var colWidth = "";
 		var isHidden = "";
		for( var i = 0; i < cols ; i++) {
			if(document.all(gridID).attribute("rowheader") != "") {
				if(i > 0) {
					if(captionList[i-1] != "" && document.all(gridID).colAttribute(i,"_hidden") != "2" ) {
						colIndex += "," + i;
						gridCaption += "," + captionList[i-1];
						isHidden += "," + document.all(gridID).colHidden(i);
						colWidth += "," + document.all(gridID).colWidth(i);
					}
				}
			} else {
				if(captionList[i] != "" && document.all(gridID).colAttribute(i,"_hidden") != "2" ) {
					colIndex += "," + i;
					gridCaption += "," + captionList[i];
					isHidden += "," + document.all(gridID).colHidden(i);
					colWidth += "," + document.all(gridID).colWidth(i);
				}
			}
		}
		model.setValue("/root/cmdHiddenPopData/colIndex",colIndex);
		model.setValue("/root/cmdHiddenPopData/gridCaption",gridCaption);
		model.setValue("/root/cmdHiddenPopData/isHidden",isHidden);
		model.setValue("/root/cmdHiddenPopData/colWidth",colWidth);

		var xPath1 = "/root/cmdHiddenPopData/colIndex" ;
		var xPath2 = "/root/cmdHiddenPopData/isHidden" ;
		var xPath3 = "/root/cmdHiddenPopData/colWidth" ;
		var popDataPath = "/root/cmdHiddenPopData";	
		
		helpGridPop("helpHidden",xPath1,xPath2,xPath3,"","",popDataPath);  //Help 창을 띄운다.
		
		colIndex = model.getValue(xPath1);
		isHidden = model.getValue(xPath2);
		colWidth = model.getValue(xPath3);
		
		var colList = colIndex.split(",");
		var hiddenList = isHidden.split(",");
		var widthList = colWidth.split(",");
		
		for(var i = 1; i < colList.length; i++) {
			if(hiddenList[i] == 1) {
				document.all(gridID).colHidden(colList[i]) = true;
			}else {
				document.all(gridID).colHidden(colList[i]) = false;
			}
			
			document.all(gridID).colWidth(colList[i]) = widthList[i];
		}
		document.all(gridID).refresh();
		// saveGridInfo();

	}catch(e) {
		alerBox("그리드가 아닙니다.");
	}
} catch(e) { model.alert(getFormID() + " => function => gridHidden => " + e, "ComMate DEBUG"); return false; }}

function gridColHidden(gridID, colRef, isHidden) {
	var col = document.all(gridID).colRef(colRef);
	if(isHidden == "1") {
		document.all(gridID).colHidden(col) = true;
		document.all(gridID).colAttribute(col,"_hidden") = "2";
	}
}

function gridColWidth(gridID, colRef, Size) {
	var col = document.all(gridID).colRef(colRef);
	document.all(gridID).colWidth(col) = Size;
}

function helpGridPop(fileName, xPath1, xPath2, xPath3, xPath4, xPath5, popDataPath)
{ try{
	var ctrlLeft;
	var ctrlTop;
	var parentObj;
	try { // 일반 컨트롤일 경우..
		ctrlLeft = parseInt(document.all(event.target).attribute("left"));
		ctrlTop = parseInt(document.all(event.target).attribute("top"));
		parentObj = document.all(event.target).parent ;
	}catch(e) {		//datagrid일 경우..
		try {
			ctrlLeft = parseInt(document.all(event.ptarget.parent.attribute("id")).attribute("left"));
			ctrlTop = parseInt(document.all(event.ptarget.parent.attribute("id")).attribute("top"));
			parentObj = document.all(event.ptarget.parent.attribute("id")).parent ;
		}catch (e) {	//수정한것....
			gridID = model.property("gridID");
			ctrlLeft = parseInt(document.all(gridID).attribute("left"));
			ctrlTop = parseInt(document.all(gridID).attribute("top"));
			parentObj = document.all(gridID).parent ;
		}
	}
	while(parentObj.elementName != "xhtml:body") {
		ctrlLeft += parseInt(parentObj.attribute("left"));
		ctrlTop += parseInt(parentObj.attribute("top"));
		parentObj = parentObj.parent ;
	}
	
	ctrlLeft += parseInt(parent.document.all("iviewerPrevMain").attribute("left"));
	ctrlTop += parseInt(parent.document.all("iviewerPrevMain").attribute("top"));

	ctrlLeft += parseInt(parent.document.all("switchMain").attribute("left"));
	ctrlTop += parseInt(parent.document.all("switchMain").attribute("top"));
	
	var popupSizeX = 280;
	var popupSizeY = 380;
	
	if (fileName == "helpHidden") { // 품번 목록
  		popupSizeX = 400;
  		popupSizeY = 500; 
 	}
 	
	var searchData = "" ;
	try{
		// 일반 텍스트 박스에서 help 창 띄울 경우...
		 model.setValue("/root/cmdHelpPopData/searchData", document.all(event.target).currentText);
	}catch(e){
		// 그리드에서 help창 띄울 경우...
 		try{
 			// 데이터 그리드 셀의 값 얻어 오기
			var target = event.ptarget.parent.attribute("id");
			var row = document.all(target).row;
			var col = document.all(target).col;
			searchData = document.all(target).valueMatrix(row,col);
			var colWidth = document.all(target).attribute("colwidth").split(",");	//그리드일때 left위치 구할때

			for( var i = 0; i < col; i++) {
				ctrlLeft += parseInt(colWidth[i]);
			}
			
			var dataHeight = document.all(target).attribute("dataheight");		//그리드일때 top위치 구할때
			ctrlTop += parseInt(dataHeight) * parseInt((row+1));
			model.setValue("/root/cmdHelpPopData/searchData",searchData);
		}catch(e){}
	}
	
	model.setValue("/root/cmdHelpPopData/xPath1", xPath1);
	model.setValue("/root/cmdHelpPopData/xPath2", xPath2);
	model.setValue("/root/cmdHelpPopData/xPath3", xPath3);
	model.setValue("/root/cmdHelpPopData/xPath4", xPath4);
	model.setValue("/root/cmdHelpPopData/xPath5", xPath5);
	model.copyNode("/root/cmdHelpPopData/popData", popDataPath);
	
	var windowX = parent.window.width;
	var windowY = parent.window.height;
	
	if((ctrlTop+popupSizeY) > windowY) {
		var tempTop = (ctrlTop+popupSizeY) - windowY;
		ctrlTop = ctrlTop - tempTop;
	}
	
	if(((ctrlLeft-(popupSizeX/2))+popupSizeX) > windowX) {
		var tempLeft = (ctrlLeft-(popupSizeX/2)+popupSizeX) - windowX;
		ctrlLeft = (ctrlLeft-(popupSizeX/2)) - tempLeft;
	} else {
		ctrlLeft = ctrlLeft-(popupSizeX/2);
	}
	
	window.load("../xrwHelp/"+fileName+".xrw","modal","", "left:"+ctrlLeft+"px; top:"
	+ctrlTop+"px; width:"+popupSizeX+"px; height:"+popupSizeY+"px; max:hidden;","/root/cmdHelpPopData","/root/cmdHelpPopData");
	
} catch(e) { model.alert(getFormID() + " => function => helpPop => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 그리드 최소값 구하기
//***************************************************
function gridMin()
{ try{
	var gridID = document.all(model.property("gridID"));
	var min;
	for(i = 0; i < gridID.selectedCells.length; i++) {
		var row = gridID.selectedCells.item(i).row;
		var col = gridID.selectedCells.item(i).col ;
		var value = gridID.valueMatrix(row,col) ;
		value = parseFloat(value);
		if (isNum(value)) {
			if(value<min || min == null)
				min = value;
		} else {
			alertBox("문자열은 계산할 수 없습니다.");
			return ;
		}
	}
	alertBox("최소값은 " + min);
	
} catch(e) { model.alert(getFormID() + " => function => gridMin => " + e, "ComMate DEBUG"); return false; }}

