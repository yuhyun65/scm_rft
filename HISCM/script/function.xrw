} catch(e) { model.alert(getFormID() + " => function => alertBox => " + e, "ComMate DEBUG"); return false; }}

//***************************************************
// ComMate: 경고창 띄우기
//***************************************************
function errAlert(msg)
{ try{
	// 언어 변환
	msg = msg + "" ; // returnSubmit(msg) ;
	
	var MyReturn = model.alert(msg, "", 0x10 | 0 );   // MB_ICONQUESTION, YesNo // 6 이면 Yes, 7 이면 No
