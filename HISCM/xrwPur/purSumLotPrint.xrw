			<col ref="ITEMNM" style="left:436px; top:20px; width:130px; height:20px; text-align:left; "/>
			<col ref="LOTQTY" format="#,###.0" style="text-align:right; "/>
			<col ref="PRCUSTNM" visibility="hidden"/>
