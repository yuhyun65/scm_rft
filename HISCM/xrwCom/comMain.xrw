<?xml version="1.0" encoding="UTF-8"?>
<xhtml:html xmlns:ex="http://www.comsquare.co.kr/xforms/excel" xmlns:xlink="http://www.w3.org/1999/xlink" xmlns:xhtml="http://www.w3.org/1999/xhtml" xmlns:my="http://www.comsquare.co.kr/example" xmlns:ms="urn:schemas-microsoft-com:xslt" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns="http://www.w3.org/2002/01/xforms" xmlns:ev="http://www.w3.org/2001/xml-events" xmlns:cs="http://www.comsquare.co.kr/xforms">
	<xhtml:head>
		<xhtml:title>:::::</xhtml:title>
		<model id="model1">
			<instance id="instance1">
				<root xmlns="">
					<changePass>
						<oldPass/>
						<newPass1/>
						<newPass2/>
					</changePass>
					<formData>
						<sendTree>
							<GroupCode/>
							<TreeView/>
							<userID/>
						</sendTree>
						<sendLogin>
							<userID/>
							<userPass/>
							<userName/>
							<isLogin>N</isLogin>
						</sendLogin>
						<iviewerPermit>
							<userID/>
							<XGPMID/>
						</iviewerPermit>
					</formData>
					<comboData>
						<GroupCode>
							<item>
								<uid/>
								<Label/>
								<PageURL/>
							</item>
						</GroupCode>
						<TreeView>
							<item>
								<PageURL/>
								<Label/>
							</item>
						</TreeView>
						<WorkGroup>
							<item>
								<label>본사</label>
								<value/>
							</item>
						</WorkGroup>
						<WorkGroupValue>main</WorkGroupValue>
						<userSetup>
							<item>
								<label>:: 그리드설정 ::</label>
								<value>list</value>
							</item>
							<item>
								<label>▷설정저장</label>
								<value>save</value>
							</item>
							<item>
								<label>▷설정초기화</label>
								<value>init</value>
							</item>
						</userSetup>
						<userSetupValue>list</userSetupValue>
					</comboData>
					<pageDesign>
						<iviewerWidth>800</iviewerWidth>
						<iviewerHeight>600</iviewerHeight>
						<menuBarShow>yes</menuBarShow>
						<menuBarFix>yes</menuBarFix>
					</pageDesign>
					<temp/>
					<CustMenu>
						<item>
							<PageURL>/xrwPur/purNapPlanReg.xrw</PageURL>
							<Label>납품예상일자등록</Label>
						</item>
						<item>
							<PageURL>/xrwPur/purNapRegister.xrw</PageURL>
							<Label>납품등록</Label>
						</item>
						<item>
							<PageURL>/xrwPur/purNapList.xrw</PageURL>
							<Label>납품조회</Label>
						</item>
						<item>
							<PageURL>/xrwPur/purLotPrint.xrw</PageURL>
							<Label>부품식별표인쇄</Label>
						</item>
						<item>
							<PageURL>/xrwPur/purSumLotPrint.xrw</PageURL>
							<Label>파레트라벨인쇄</Label>
						</item>
						<item>
							<PageURL>/xrwPur/purSumLotRePrint.xrw</PageURL>
							<Label>파레트라벨재인쇄</Label>
						</item>
						<item>
							<PageURL>/xrwPur/purAccount.xrw</PageURL>
							<Label>거래명세서인쇄</Label>
						</item>
						<item>
							<PageURL>/xrwPur/purStokList.xrw</PageURL>
							<Label>재고조회</Label>
						</item>
						<item>
							<PageURL>/xrwBoard/boardA001_List.xrw</PageURL>
							<Label>업체게시판</Label>
						</item>
						<item>
							<Label>품질정보</Label>
							<item>
								<PageURL>/xrwDoc/AODocSendList6.xrw</PageURL>
								<Label>대표이사 신문고</Label>
							</item>
							<item>
								<PageURL>/xrwDoc/AODocSendList1.xrw</PageURL>
								<Label>부적합 통지</Label>
							</item>
							<item>
								<PageURL>/xrwDoc/AODocSendList2.xrw</PageURL>
								<Label>개선대책서 등록</Label>
							</item>
							<item>
								<PageURL>/xrwDoc/AODocSendList3.xrw</PageURL>
								<Label>정기신뢰성자료</Label>
							</item>
							<item>
								<PageURL>/xrwDoc/AODocSendList4.xrw</PageURL>
								<Label>업체 시정조치 사항</Label>
							</item>
							<item>
								<PageURL>/xrwDoc/AODocSendList5.xrw</PageURL>
								<Label>품질 요청 자료</Label>
							</item>
						</item>
					</CustMenu>
					<AdminMenu>
						<item>
							<Label>품질정보</Label>
							<item>
								<PageURL>/xrwDoc/AODocSendList6.xrw</PageURL>
								<Label>대표이사 신문고</Label>
							</item>
							<item>
								<PageURL>/xrwDoc/AODocSendList.xrw</PageURL>
								<Label>전체공지</Label>
							</item>
							<item>
								<PageURL>/xrwDoc/AODocSendList1.xrw</PageURL>
								<Label>부적합 통지</Label>
							</item>
							<item>
								<PageURL>/xrwDoc/AODocSendList2.xrw</PageURL>
								<Label>개선대책서 등록</Label>
							</item>
							<item>
								<PageURL>/xrwDoc/AODocSendList3.xrw</PageURL>
								<Label>정기신뢰성자료</Label>
							</item>
							<item>
								<PageURL>/xrwDoc/AODocSendList4.xrw</PageURL>
								<Label>업체 시정조치 사항</Label>
							</item>
							<item>
								<PageURL>/xrwDoc/AODocSendList5.xrw</PageURL>
								<Label>품질 요청 자료</Label>
							</item>
						</item>
						<item>
							<PageURL>/xrwBoard/noticeA001_List.xrw</PageURL>
							<Label>공지사항</Label>
						</item>
						<item>
							<PageURL>/xrwBoard/boardA001_List.xrw</PageURL>
							<Label>업체게시판</Label>
						</item>
						<item>
							<PageURL>/xrwCom/comCustList.xrw</PageURL>
							<Label>거래처로그인</Label>
						</item>
					</AdminMenu>
					<sendFiles>
						<file1/>
						<fileuid/>
					</sendFiles>
				</root>
			</instance>
		</model>
		<script type="javascript">
			<![CDATA[
			
				var clockTimer;
				var itime = 1000*60*5;
				function TimeSch()
				{
					document.all("btnTimer").dispatch("onclick");
				}
				function TimeStart()
				{
					clockTimer = window.setInterval("TimeSch()", itime);	
				}
				function TimeEnd()
				{
					 window.clearInterval(clockTimer);
				}
				function mateInit() { // 초기 로딩
					setTitle(); // 타이틀 지정
					copyUserInfo() ; 
					// changeLang();
					loginBtn.dispatch("onclick") ; 
					// 자동 로그인 ( 페이지 리사이징 로그인 성공시 수행 )
					
					var userID = getUserID();					
					if (userID == "mateadmin" || userID == "dhdo")
					{
						model.setValue("/root/formData/sendLogin/isAdmin", "Y");
					}
				}
				// 전체 페이지 자동 크기 조절
				function mainPageResize() {
					// 최대화 및 iviewerWidth창 크기 얻기
					window.maximize() ;  
					var iviewerWidth = window.width - 10;
					var iviewerHeight = window.height - 140 ;
					
					// Hidden Bar 설정에 따른 페이지 조절
					var isShow = model.getValue("/root/pageDesign/menuBarShow");
					if (isShow == "yes") {
						groupHidden.attribute("visibility") = "visible" ;
						groupPrevPage.attribute("left") = "200px" ; 
						groupBtn.attribute("left") = "200px" ;
						switchMain.attribute("left") = "200px" ;
						captionPrevMain.attribute("left") = "10px" ;
						iviewerWidth -= 200 ;
					} else {
						groupHidden.attribute("visibility") = "hidden" ;
						groupPrevPage.attribute("left") = "15px" ; 
						groupBtn.attribute("left") = "15px" ;
						switchMain.attribute("left") = "15px" ;
						captionPrevMain.attribute("left") = "25px" ;
						iviewerWidth -= 15 ;
					}
					
					// iviewer 사이즈 인스턴스에 저장
					model.setValue("/root/pageDesign/iviewerWidth", iviewerWidth);
					model.setValue("/root/pageDesign/iviewerHeight", iviewerHeight);

					groupHidden.attribute("height") = iviewerHeight + 100 + "px" ; 
					treeview1.attribute("height") = iviewerHeight + 100 - 135 + "px" ;
					
					groupPrevPage.attribute("width") = iviewerWidth + "px" ; 
					groupBtn.attribute("width") = iviewerWidth + "px" ; 
					
					switchMain.attribute("width") = iviewerWidth + "px" ;
					switchMain.attribute("height") = iviewerHeight + 60 + "px" ;
					
					// iviewer 크기 조절
					iviewerResize();		
				}

				function iviewerResize() {
					var iviewerWidth = model.getValue("/root/pageDesign/iviewerWidth");
					var iviewerHeight = model.getValue("/root/pageDesign/iviewerHeight");
					var iviewerObj = switchMain.children.item(switchMain.selectedIndex).children.item(3);
					iviewerObj.attribute("style") = "height:"+ iviewerHeight + "px; width:"+ iviewerWidth + "px;" ;
					try {
						// iviewer 문서 속의 pageResize() 호출
						iviewerObj.window.javascript.pageResize();
					} catch(e) {}
							
					var itemIndex = switchMain.selectedIndex ;
					var selectedCase = switchMain.children.item(itemIndex).attribute("id") ;			
					var pageName = selectedCase.substring(8,selectedCase.length);
								
					btnPrint.disabled = true;					
					if(pageName == "purSumLotRePrint" || pageName == "purLotPrint" || pageName == "purSumLotPrint" || pageName == "purAccount")
					{
						btnPrint.disabled = false;						
					}	
				}
					
				// 탭 메뉴 간격 조절 하기
				function shiftTab() {
					// 버튼 탭 길이와 버튼 탭 갯수 얻기
					var groupWidth = parseInt(groupPrevPage.attribute("width")) ;
					var tabList = groupPrevPage.children ;

					var btnWidth = 79 ; // 기본 버튼 탭 길이 지정 
					// 전체 그룹 길이 초과하지 않도록 버튼 길이 조절
					while ( (btnWidth * tabList.length + 10) > groupWidth ) {
						btnWidth -= 10 ; 
					}
					// 조절된 버튼 길이 만큼 배치
					for (var i=0; i<tabList.length; i++) {
						tabList.item(i).attribute("left") = (10 + btnWidth * i ) + "px" ;
					}
				}
				
				// 버튼 배경 이미지 설정
				function setButton() {
					var styleType = model.getValue("/root/cmdMdbUserInfo/styleType") ;
					var colorType = styleType.substring(0,1) ;
				
					var obj = document.controls ;
					for (var i=0; i<obj.length; i++) {
						var ctrlEle = obj.item(i).elementName;
						if (ctrlEle == "xforms:button") { 
							var isComm = obj.item(i).attribute("_type");
							var isGroup = obj.item(i).attribute("group") ;
							if (((isGroup == null) || (isGroup == "")) && (isComm != "common")) { 
							// 일반 버튼 일 경우 설정, 공통 메뉴는 디자인 시점에서 직접 설정
								var btnText = obj.item(i).text ; 
								var btnLength = btnText.length ;  // 버튼 텍스트 길이
								if (!isKor(btnText)) btnLength = parseInt((btnLength+1)/2) ;  // 한글일 경우 영문길이와 맞춤
								if (btnLength>5) btnLength = 5 ;  // 최대 5글자로 제한
								else if (btnLength<2) btnLength = 2 ; // 최소 2글자로 제한
								
								// 버튼 배경과 버튼 길이 설정
								obj.item(i).attribute("style") = "background-image:../images/button/"+ colorType +"Length"+ btnLength +".jpg" ;
								obj.item(i).attribute("style") = "width:"+(55 + 15*(btnLength -2))+"px; text-align:right; border-style:solid; padding-right:5;" ;
								
							} 
						} 
					}
				}
				
				// 로그인 현재 시각 타이머
				function loginTimer() {
					curTime.text = getTime("hh:mm:ss");
				}
			]]>
		</script>
	</xhtml:head>
	<xhtml:body>
		<import id="import1" src="../script/Common.xrw" style="left:0px; top:0px; width:0px; height:0px; "/>
		<img id="imgHiddenBar" src="../images/button/yHiddenBar.jpg" style="left:0px; top:0px; width:15px; height:300px; font-size:10pt; background-stretch:stretch; cursor:hand; ">
			<script type="javascript" ev:event="onclick">
				<![CDATA[
					// Hidden Bar 닫기 버튼 눌렀을 때
					var isShow = model.getValue("/root/pageDesign/menuBarShow");
					if (isShow == "yes") {
						model.setValue("/root/pageDesign/menuBarShow", "no");
					} else {
						model.setValue("/root/pageDesign/menuBarShow", "yes");
					}
					mainPageResize(); // 페이지 리사이징
					shiftTab(); // 탭 버튼 간격 조절
				]]>
			</script>
		</img>
		<group id="groupPrevPage" scroll="none" style="left:200px; top:0px; width:800px; height:40px; ">
			<button id="btnPrevMain" group="btnPrevPage" selected="true" style="left:10px; top:15px; width:80px; height:25px; ">
				<caption>공지사항</caption>
				<script type="javascript" ev:event="onclick">
					<![CDATA[
					model.toggle("casePrevMain") ; 
					iviewerResize(); // iviewer 크기 조절
					shiftTab();
					]]>
				</script>
			</button>
		</group>
		<switch id="switchMain" class="color3" style="left:200px; top:40px; width:800px; height:600px; ">
			<case id="casePrevMain">
				<iviewer id="iviewerPrevMain" style="left:0px; top:60px; width:800px; height:530px; "/>
				<caption id="captionPrevMain" style="left:10px; top:5px; width:500px; height:20px; font-size:10pt; vertical-align:middle; ">:: (주) 한일정밀 웹발주시스템 :::</caption>
				<group id="progress" visibility="hidden" popup="true" style="left:250px; top:200px; width:285px; height:50px; background-color:#eeeeee; border-style:solid; ">
					<caption id="progresstext" style="left:15px; top:15px; width:243px; height:20px; vertical-align:middle; ">※ 진행중입니다. 잠시만 기다려주십시오.</caption>
				</group>
			</case>
		</switch>
		<group id="groupBtn" class="color2" scroll="none" style="left:200px; top:70px; width:800px; height:30px; font-size:10pt; ">
			<script type="javascript" ev:event="onclick">
				<![CDATA[

				// 공통 버튼 클릭 시 ( 이벤트 버블링으로 처리 )				
				var itemIndex = switchMain.selectedIndex ;
				var selectedCase = switchMain.children.item(itemIndex).attribute("id") ;
				var pageName = selectedCase.substring(8,selectedCase.length);
					
				if (event.target == "btnSearch") {	//조회버튼을 눌렀을때..
					try { 
						//조회 권한이 있는지 확인한다.			
						var XGSRYN = document.all(selectedCase).children.item(3).model.getValue("/root/cmdPagePermit/XGSRYN") ;
						if(XGSRYN == "Y") {
							document.all(selectedCase).children.item(3).window.javascript.mateSearch();
							document.all(selectedCase).children.item(3).window.javascript.addGridCol();
							document.all(selectedCase).children.item(3).window.model.refresh();
						} else {
							alertBox("조회 권한이 없습니다. \n\n관리자에게 문의하십시요.  ");
						}
					 } catch(e) { }
				} else if (event.target == "btnAdd") {	//추가 버튼을 눌렀을때..
					try {
						//추가 권한이 있는지 확인한다..
						var XGINYN = document.all(selectedCase).children.item(3).model.getValue("/root/cmdPagePermit/XGINYN") ;
						if(XGINYN == "Y") {
							document.all(selectedCase).children.item(3).window.javascript.mateAdd(); 
						} else {
							alertBox("추가 권한이 없습니다. \n\n관리자에게 문의하십시요. ");
						}
					 } catch(e) {} 
				} else if (event.target == "btnSave") {		// 저장버튼을 눌렀을때..
					try {
						// 저장 권한이 있는지 확인한다.
						var XGSVYN = document.all(selectedCase).children.item(3).model.getValue("/root/cmdPagePermit/XGSVYN") ;
						if(XGSVYN == "Y") {
							document.all(selectedCase).children.item(3).window.javascript.mateSave(); 
						} else {
							alertBox("저장 권한이 없습니다. \n\n관리자에게 문의하십시요.  ");
						}
					 } catch(e) {} 
				} else if (event.target == "btnDel") {		//삭제버튼을 눌렀을때..
					try {
						//삭제 권한이 있는지 확인한다.
						var XGDEYN = document.all(selectedCase).children.item(3).model.getValue("/root/cmdPagePermit/XGDEYN") ;
						if(XGDEYN == "Y") {
							document.all(selectedCase).children.item(3).window.javascript.mateDel(); 
						} else {
							alertBox("삭제 권한이 없습니다. \n\n관리자에게 문의하십시요.  ");
						}
					 } catch(e) {} 
				} else if (event.target == "btnPrint") {		//프린트 버튼을 눌렀을때..
					try {
						//프린트 권한이 있는지 확인한다.
						var XGPTYN = document.all(selectedCase).children.item(3).model.getValue("/root/cmdPagePermit/XGPTYN") ;
						if(XGPTYN == "Y") {
//							var ret = TFStarter.getConfig(rootURL+"/install/printConfig.jsp");
//							if (ret == false) {
//								alert("프린트 모듈을 설치하지 못하였습니다. \n\n출력 오류 발생 시 관리자한테 문의하세요.");
//							}
							document.all(selectedCase).children.item(3).window.javascript.matePrint(); 
						} else {
							alertBox("프린트 권한이 없습니다. \n\n관리자에게 문의하십시요.  ");
						}
					 } catch(e) {} 
				} else if (event.target == "btnExcel") {	//엑셀 버튼을 눌렀을때..
					//엑셀 권한이 있는지 확인힌다.
					var XGEXYN = document.all(selectedCase).children.item(3).model.getValue("/root/cmdPagePermit/XGEXYN") ;
					if(XGEXYN == "Y") {
//						alertBox("엑셀파일로 출력할 그리드를 마우스로 클릭하세요.  ");
//						document.all(selectedCase).children.item(3).model.setValue("/root/cmdExcelFlag",1);
						document.all(selectedCase).children.item(3).window.javascript.mateExcel(); 
					} else {
						alertBox("엑셀 권한이 없습니다.	\n\n관리자에게 문의하십시요.  ");
					}
				} else if (event.target == "btnClose") {			
					if (pageName == "purNapRegister" || pageName == "purNapPlanReg")
						window.clearInterval(clockTimer);	
						
					if (selectedCase == "casePrevMain") { // 메인 화면일 때...									
						if (groupPrevPage.children.length > 1) {
							alertBox("열려 있는 모든 페이지를 닫으십시요. ");
							var lastItem = groupPrevPage.children.length - 1 ;
							groupPrevPage.children.item(lastItem).dispatch("onclick");
						} else {
							var isCloseAll = yesAlert("메인 화면입니다.\n\n전체 화면을 닫으시겠습니까?  ") ;
							if (isCloseAll == 1) { // 전체 창을 닫고자 할 경우...
								window.close() ; 
							}
						}
					} else { // 메인 화면이 아닐 경우...
						try {
							var isClose = 1 ;
							try { 
								// 페이지 내부 mateClose() 호출
								var ok = document.all(selectedCase).children.item(3).window.javascript.mateClose(); 
								// mateClose() 리턴값이 없거나 함수가 존재하지 않다면 ok 값은 null 혹은 ""
								// 닫지 못하게 하려면 ok 리턴 값을 0, false,"false", "False" 로 주면 된다. 
								if (ok == 0 || ok == false || ok == "false" || ok == "False") 
									isClose = 0 ; 
							} catch(e) { isClose = 1 ; }
							
							if (isClose == 1) {  // 제대로 실행되었거나 처리 로직이 없을 시 닫기
							
								switchMain.removeChild(selectedCase);
								groupPrevPage.removeChild("btnPrev"+pageName) ;

								// 다음 버튼으로 이동
								var lastItem = groupPrevPage.children.length - 1 ;
								var delItem = itemIndex + 3 ;
								if (lastItem >= delItem) {
									toBtnName = groupPrevPage.children.item(delItem).attribute("id") ;
								} else {
									toBtnName = groupPrevPage.children.item(lastItem).attribute("id") ;
								}
								document.all(toBtnName).dispatch("onclick");
								
								iviewerResize();
								shiftTab() ;
							}
							
						} catch(e) {}
					}
				} 				
				]]>
			</script>
