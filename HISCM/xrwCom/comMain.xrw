			<button id="btnTimer" visibility="hidden" style="left:570px; top:5px; width:100px; height:20px; ">
				<caption>button11</caption>
				<script type="javascript" ev:event="onclick">
					<![CDATA[
								
						var itemIndex = switchMain.selectedIndex ;
						var selectedCase = switchMain.children.item(itemIndex).attribute("id") ;
						var pageName = selectedCase.substring(8,selectedCase.length);
							
						if (pageName == "purNapRegister" || pageName == "purNapPlanReg")
						{
							document.all(selectedCase).children.item(3).window.javascript.matetimer();
