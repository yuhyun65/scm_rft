		<group id="groupHidden" scroll="none" style="left:15px; top:0px; width:185px; height:640px; background-color:transparent; border-style:none; ">
			<treeview id="treeview1" ref="/root/formData/sendTree/TreeView" class="color2" navindex="6" expanddepth="1" hasimages="true" itemsettype="node" oneclickexpand="true" style="left:0px; top:150px; width:185px; height:490px; padding-top:10; border-style:none; ">
				<itemset nodeset="/root/comboData/TreeView/item">
					<label ref="Label"/>
					<value ref="PageURL"/>
				</itemset>
				<script type="javascript" ev:event="ondblclick">
					<![CDATA[
					// 트리 메뉴 더블 클릭 시
					var userID = model.getValue("/root/formData/sendLogin/userID");
					if (model.getValue("/root/formData/sendLogin/isLogin") == "Y") { // 로그인 상태라면...

						// 선택 아이템 정보 얻어오기
						var itemIndex = treeview1.selectedIndex + 1;
						var PageURL = treeview1.value;
						var Label = treeview1.label;
						
						if (PageURL == "") return;
						
						var pageStr = PageURL.split("/");
						var pageName = pageStr[pageStr.length-1].replace(".xrw", "");
													
						// prevButton 설정
						var btnName = Label ;
						if (isEng(Label.replace(" ", ""))) {
							if (Label.length>= 9) btnName = Label.substring(0, 7) + ".." ;
						} else {
							if (Label.length >= 6) btnName = Label.substring(0, 4) + ".." ;
						}
												// 열려져 있는 페이지 인지 확인
						var case_exist = switchMain.isChild("casePrev" + pageName);
						if( !case_exist ){ // 열려져 있지 않은 페이지라면 해당 Prev탭 추가

							// Switch Case 추가	
							var switchCase = switchMain.createChild("xforms:case","id:casePrev"+ pageName +";");
							
							// iviewer 추가 ( src를 지정하지 않은 빈 페이지 생성 )
							var iviewerWidth = model.getValue("/root/pageDesign/iviewerWidth");
							var iviewerHeight = model.getValue("/root/pageDesign/iviewerHeight");
							switchCase.createChild("xforms:iviewer","id:iviewerPrev"+pageName+";left:0px; top:60px; width:"+iviewerWidth+"px; height:"+iviewerHeight+"px;");
							
							// 캡션 추가
							switchCase.createChild("xforms:caption","id:captionPrev"+pageName+";left:10px; top:5px; width:500px; height:20px; font-size:10pt; vertical-align:middle; ");							
	
							// Prev그룹에 탭 버튼 추가
							var btnList = groupPrevPage.children ; 
							var left = btnList.item(btnList.length-1).attribute("left") ; 
							var tabButton = groupPrevPage.createChild("xforms:button","id:btnPrev"+pageName+";text:"+btnName
										+";group:btnPrevPage;selected:true;left:"+ left +"px; top:15px; width:80px; height:25px;");
										
							if (pageName == "purNapRegister" || pageName == "purNapPlanReg")
								tabButton.attribute("onclick") = "model.toggle('casePrev"+pageName+"');iviewerResize();clockTimer = window.setInterval('TimeSch()', "+itime+");";
							else
								tabButton.attribute("onclick") = "model.toggle('casePrev"+pageName+"');iviewerResize();window.clearInterval(clockTimer);";						               

							// iviewerPage 권한 가져오기							
							sendBuffInit();
							submit("sp_SCM_MemberShip", "GetAuthority");

							// iviewer 페이지로 권한 복사
							model.copyNode("/root/cmdPagePermit", "/root/msgBuff/data/item");
							
							// iviewer 실제 페이지 로딩
							var pageSrc = rootURL + PageURL ;
							document.all("iviewerPrev"+pageName).src = pageSrc ;
							
							var sINSGB = "";
							if (pageName.indexOf("AODocSendList") != -1)
							{
								sINSGB = pageName.replace("AODocSendList", "");
								document.all("iviewerPrev"+pageName).model.setValue("/root/INSGB", sINSGB);
//								PageURL = PageURL.replace(pageName, "AODocSendList");
//								pageName = "AODocSendList";
							}
							
							var isLoading = 1 ;  // 페이지 로딩 성공 여부 확인 필드
							try { 
								var node = document.all("iviewerPrev"+pageName).instance1.selectSingleNode("/root/cmdPagePermit") ;
								// iviewer 페이지 node 접근 오류 발생 시 예외 방생 즉 페이지 로딩 실패								
							} catch(e) {
								isLoading = -1 ;
							}
													
							// 페이지 로딩 실패 시 창 닫기 및 alert창 띄우기
							if (isLoading == -1) {
								model.toggle("casePrev"+pageName+""); // 추가된 페이지로 이동
								btnClose.dispatch("onclick"); // 페이지 닫기
								alertBox("해당 페이지가 없거나 로딩하지 못하였습니다.");
							} else { // 페이지 로딩 성공 시
								model.toggle("casePrev"+pageName+""); // 추가된 페이지로 이동
																
								// 페이지 경로 캡션 추가
								var menu = " > " + Label ;
								var depth = model.getValue("/root/comboData/TreeView/item["+ itemIndex +"]/Depth");
								searchDepth = depth - 1 ;
								for (var i=itemIndex; i>=0; i--) {  // 상위 메뉴 검색해서 현재 경로 앞에 추가
									var parentDepth = model.getValue("/root/comboData/TreeView/item["+ i +"]/Depth");
									if (parentDepth == searchDepth) {
										var parentLabel = model.getValue("/root/comboData/TreeView/item["+ i +"]/Label");
										menu = " > " + parentLabel + menu ;
										searchDepth-- ;
									} 
									if (searchDepth == 0) { // 최 상위 메뉴라면
										// var curGroupCode = model.getValue("/root/formData/sendTree/GroupCode") ;
										// var GroupName = model.getValue("/root/comboData/GroupCode/item[uid = "+curGroupCode+"]/Label");
										menu = ":: SCM" + menu ;
										break;
									}
								}	
								document.all("captionPrev"+pageName).text = menu ;
							
								iviewerResize(); // 페이지 리사이징
								shiftTab(); // 탭 간격 조절
							}
							
						} else { // 이미 열려진 페이지라면 해당 페이지로 이동
							document.all("btnPrev"+pageName).dispatch("onclick") ;			
						}														
						if (pageName == "purNapRegister" || pageName == "purNapPlanReg")
							clockTimer = window.setInterval("TimeSch()", itime);	
						else
					               window.clearInterval(clockTimer);
	
					} else { // 로그아웃 상태라면...
						alertBox("로그인 하셔야 해당 메뉴의 이용이 가능합니다");
					}
					]]>
				</script>
			</treeview>
			<group id="groupMenuBar" class="color5" style="left:0px; top:0px; width:185px; height:25px; font-size:10pt; ">
				<img id="imgMiniClose" src="../images/button/yMiniClose.jpg" style="left:160px; top:5px; width:15px; height:15px; background-stretch:stretch; cursor:hand; ">
					<script type="javascript" ev:event="onclick">
						<![CDATA[
							// Hidden Bar 닫기 버튼 누를 시
							model.setValue("/root/pageDesign/menuBarShow", "no");
							mainPageResize();
							shiftTab();
						]]>
					</script>
				</img>
				<img id="imgMiniFix" src="../images/button/yMiniFix.jpg" style="left:140px; top:5px; width:15px; height:15px; background-stretch:stretch; cursor:hand; ">
					<script type="javascript" ev:event="onclick">
						<![CDATA[
							// Hidden Bar 고정 핀 눌렀을 시
							var isFix = model.getValue("/root/pageDesign/menuBarFix") ;
							if (isFix == "yes") {
								model.setValue("/root/pageDesign/menuBarFix", "no") ;
								imgMiniFix.src = "../images/button/yMiniFixHidden.jpg" ;
								imgMiniFix.attribute("left") = "139px" ;
								imgMiniFix.attribute("left") = "140px" ;
							} else {
								model.setValue("/root/pageDesign/menuBarFix", "yes") ;
								imgMiniFix.src = "../images/button/yMiniFix.jpg" ;
								imgMiniFix.attribute("left") = "139px" ;
								imgMiniFix.attribute("left") = "140px" ;
							}				
						]]>
					</script>
				</img>
				<caption id="caption8" style="left:10px; top:0px; width:125px; height:25px; font-size:9pt; font-weight:bold; color:#ffffff; vertical-align:middle; ">::: MENU BAR :::</caption>
			</group>
			<switch id="switchLogin" class="color1" style="left:0px; top:25px; width:185px; height:125px; ">
				<case id="caseLogout" selected="true">
					<input id="loginUserID" ref="/root/formData/sendLogin/userID" navindex="1" imemode="alpha" maxlength="15" style="left:70px; top:30px; width:100px; height:20px; vertical-align:bottom; ">
						<script type="javascript" ev:event="onkeyup">
							<![CDATA[
							// 로그인 버튼 엔터 키 누를 때
							if (event.keyCode == 13) {
								model.setFocus("loginBtn");
								loginBtn.dispatch("onclick") ;
							}		
							]]>
						</script>
					</input>
					<secret id="loginUserPass" ref="/root/formData/sendLogin/userPass" navindex="2" imemode="alpha" maxlength="20" appearance="secret" style="left:70px; top:55px; width:100px; height:20px; vertical-align:bottom; ">
						<script type="javascript" ev:event="onkeyup">
							<![CDATA[
							// 로그인 비밀 번호 엔터 키 누를 때
							if (event.keyCode == 13) {
								model.setFocus("loginBtn");
								loginBtn.dispatch("onclick") ;
							}		
							]]>
						</script>
					</secret>
					<caption id="caption9" style="left:10px; top:30px; width:55px; height:20px; font-size:9pt; font-weight:bold; color:#ffffff; text-align:right; vertical-align:middle; ">아 이 디</caption>
					<caption id="caption10" style="left:10px; top:55px; width:55px; height:20px; font-size:9pt; font-weight:bold; color:#ffffff; text-align:right; vertical-align:middle; ">비밀번호</caption>
					<button id="loginBtn" navindex="3" style="left:100px; top:90px; width:70px; height:20px; text-align:right; ">
						<caption>로그인</caption>
						<script type="javascript" ev:event="onclick">
							<![CDATA[						
							// 로그인 처리
							sendBuffInit();
							sendBuffAdd("UserID", model.getValue("/root/formData/sendLogin/userID"));
							sendBuffAdd("UserPass", model.getValue("/root/formData/sendLogin/userPass"));	
							submit("sp_SCM_MemberShip", "Login");
							
							var userID =  model.getValue("/root/msgBuff/data/item/userID");
							var userName = model.getValue("/root/msgBuff/data/item/userName");
							
							if (userID == "NO_USERID") {
								alertBox("로그인에 실패하였습니다. \n\n존재하지 않는 아이디입니다. ");
								loginUserID.value = "" ;
								loginUserPass.value = "";
								model.setFocus("loginUserID");
							} else if (userID == "NO_USERPASS") {
								alertBox("로그인에 실패하였습니다. \n\n비밀번호가 맞지 않습니다. ");
								loginUserPass.value = "";
								model.setFocus("loginUserPass");
							} else { // 로그인 성공 시
							
								loginUserID.value = userID;
								
								model.copyNode("/root/formData/sendLogin", "/root/msgBuff/data/item");
								
								model.toggle("caseLogin") ;						
								
								var getLoginTime = getTime("hh:mm:ss");
								loginTime.text = getLoginTime ;
								window.setInterval("loginTimer();", 1000); // 1초마다 loginTimer() 호출
								
								//if (userID.substring(0,1) == "C" || userID.substring(0,1) == "c")
//								if (userID == "mateadmin"  || userID == "dhdo")
								if (model.getValue("/root/formData/sendLogin/isAdmin") == "Y") 	
								{
									if (userID != "jhlee" && userID == "mateadmin")
									{
										model.removenode("/root/AdminMenu/item/item[0]");
									}				
														
									model.copyNode("/root/comboData/TreeView", "/root/AdminMenu");
								} else {
									model.copyNode("/root/comboData/TreeView", "/root/CustMenu");									
								}
								
								model.refresh();
								treeview1.rebuild();

								// 로그인 성공 시 iviewer 에 공지사항 띄우기
								iviewerPrevMain.src="../xrwBoard/mainNotice.xrw" ;

								mainPageResize();  // 페이지 리사이징
								shiftTab() ;  // 스위치 탭 간격 조절
								setButton();  // 버튼 크기와 배경 설정 하기
								
								//외주업체인경우만 비번변경 가능하도록
								if (model.getValue("/root/formData/sendLogin/isAdmin") == "N")
									button4.visible = true;
								else
									button4.visible = false;
							}
							
							]]>
						</script>
					</button>
					<button id="userSetup" navindex="4" visibility="hidden" style="left:5px; top:90px; width:85px; height:20px; text-align:right; ">
						<caption>환경설정</caption>
						<script type="javascript" ev:event="onclick">
							<![CDATA[
								alertBox("로그인 하셔야 환경설정을 할 수 있습니다.");			
							]]>
						</script>
					</button>
				</case>
				<case id="caseLogin">
					<caption id="caption13" style="left:10px; top:30px; width:90px; height:20px; font-weight:bold; color:#ffffff; text-align:right; vertical-align:middle; ">로그인 시간 :</caption>
					<button id="logoutBtn" navindex="3" style="left:90px; top:75px; width:85px; height:20px; text-align:right; ">
						<caption>로그아웃</caption>
						<script type="javascript" ev:event="onclick">
							<![CDATA[
							model.setValue("/root/formData/sendLogin/isLogin", "N");
							// 초기 페이지 권한 초기화
							var pagePermit = instance1.selectSingleNode("/root/cmdPagePermit");
							model.resetInstanceNode(pagePermit);
							
							var pageLength = groupPrevPage.children.length ;
							for (var i=0 ; i < pageLength-1 ; i++) {
								try {
									var pageName = groupPrevPage.children.item(groupPrevPage.children.length - 1).attribute("id").replace("btnPrev", "");
									var isClose = 1 ;
									try { 
										var ok = document.all("casePrev"+pageName).children.item(3).window.javascript.mateClose(); 
										if (ok == 0 || ok == false ) 
											isClose = 0 ; 
									} catch(e) { isClose = 1 ; }
									
									if (isClose == 1) {
										switchMain.removeChild("casePrev"+pageName);
										groupPrevPage.removeChild("btnPrev"+pageName) ;
									}
									
								} catch(e) {}
							}
							document.all("btnPrevMain").dispatch("onclick");
							// 열려있는 창 닫기
							
							//model.copyNode("/root/sendBuff", "/root/temp");
							//submit("comLogout") ;
							
							//var userID = model.getValue("/root/msgBuff/userID");
							//var userName = model.getValue("/root/msgBuff/userName");
							
							//model.copyNode("/root/SESSION", "/root/msgBuff/SESSION");

							model.toggle("caseLogout");
							
							loginUserID.value = "";
							loginUserPass.value = "";
							
							model.copyNode("/root/comboData/TreeView", "/root/comboData/TreeView");
							treeview1.rebuild();
							
							model.setFocus("loginUserID");

							]]>
						</script>
					</button>
					<button id="button4" navindex="4" style="left:0px; top:75px; width:80px; height:20px; text-align:right; vertical-align:middle; ">
						<caption>비번변경</caption>
						<script type="javascript" ev:event="onclick">
							<![CDATA[
								groupChangePW.visible = true;	
								oldPass.value = "";
								newPass1.value = "";
								newPass2.value = "";
								model.setFocus("oldPass");	
							]]>
						</script>
					</button>
					<caption id="caption16" style="left:10px; top:50px; width:90px; height:20px; font-weight:bold; color:#ffffff; text-align:right; vertical-align:middle; ">현재 시간 :</caption>
					<caption id="loginUserName" ref="/root/formData/sendLogin/userName" style="left:5px; top:5px; width:170px; height:20px; font-weight:bold; color:#99ff99; text-align:center; vertical-align:middle; ">(주) 컴퓨터메이트</caption>
					<caption id="loginTime" style="left:100px; top:30px; width:60px; height:20px; font-weight:bold; color:#ffffff; text-align:left; vertical-align:middle; ">12:00</caption>
					<caption id="curTime" style="left:100px; top:50px; width:60px; height:20px; font-weight:bold; color:#ffffff; text-align:left; vertical-align:middle; ">12:00</caption>
					<button id="button5" style="left:0px; top:100px; width:80px; height:20px; text-align:right; vertical-align:middle; ">
						<caption>도장사진</caption>
						<script type="javascript" ev:event="onclick">
							<![CDATA[
			
						var fileList = window.fileDialog("open", "|", true);
						var filename = fileList.split("|");
						
						if(fileList != ""){
							for (var i=0 ; i< filename.length ; i++) {
								model.setValue("/root/sendFiles/file1", filename[i]);
							}
						}							
						upload("TrustBoard", "add", "0");
						var fileUid = model.getValue("/root/msgBuff/msgFiles/fileUID");;
						model.setValue("/root/sendFiles/fileuid", fileUid);
														
						sendBuffInit();
						sendBuffAdd("UserID", getUserID());
						sendBuffAdd("fileuid", fileUid);
						submit("sp_SCM_MemberShip", "fileuid_upd");
									
					]]>
						</script>
					</button>
					<upload id="upload1" nodeset="/root/sendFiles/file1" style="left:134px; top:99px; width:25px; height:20px; "/>
				</case>
			</switch>
			<group id="groupGroupCombo" class="color2" visibility="hidden" style="left:0px; top:150px; width:185px; height:40px; ">
				<select1 id="comboGroup" ref="/root/formData/sendTree/GroupCode" navindex="5" appearance="minimal" style="left:10px; top:10px; width:160px; height:20px; ">
					<choices>
						<itemset nodeset="/root/comboData/GroupCode/item">
							<label ref="Label"/>
							<value ref="uid"/>
						</itemset>
					</choices>
					<script type="javascript" ev:event="xforms-value-changed">
						<![CDATA[
						// 그룹 변경 시
//						model.setValue("/root/formData/sendTree/GroupCode", comboGroup.value) ;
//						model.setValue("/root/formData/sendTree/QueryKind", "byGroupCode");
//						model.copyNode("/root/sendBuff", "/root/formData/sendTree");
//						submit("comMain");
//						setTreeMenu();
					]]>
					</script>
				</select1>
			</group>
		</group>
		<script type="javascript" ev:event="onmousemove">
			<![CDATA[
				// 마우스 이동 시 Hidden Bar 숨기고 보이기
				var mouseX = event.clientX ;
				if (mouseX > 200) {
					var isFix = model.getValue("/root/pageDesign/menuBarFix") ;
					var isShow = model.getValue("/root/pageDesign/menuBarShow");
					if ( (isFix == "no") && (isShow == "yes") ) {
						model.setValue("/root/pageDesign/menuBarShow", "no") ;
						mainPageResize();
						shiftTab();
					}
				} else if (mouseX < 15) {
					var isFix = model.getValue("/root/pageDesign/menuBarFix") ;
					var isShow = model.getValue("/root/pageDesign/menuBarShow");
					if ( (isFix == "no") && (isShow == "no") ) {
						model.setValue("/root/pageDesign/menuBarShow", "yes") ;
						mainPageResize();
						shiftTab();
					}
				}
			]]>
		</script>
		<group id="groupChangePW" visibility="hidden" popup="true" style="left:25px; top:125px; width:245px; height:116px; background-color:#ccffcc; border-style:solid; ">
			<secret id="oldPass" ref="/root/changePass/oldPass" maxlength="20" appearance="secret" style="left:99px; top:9px; width:130px; height:20px; "/>
			<secret id="newPass1" ref="/root/changePass/newPass1" maxlength="15" appearance="secret" style="left:99px; top:34px; width:130px; height:20px; "/>
			<secret id="newPass2" ref="/root/changePass/newPass2" maxlength="15" appearance="secret" style="left:99px; top:59px; width:130px; height:20px; "/>
			<caption id="caption1" style="left:9px; top:9px; width:84px; height:20px; text-align:right; vertical-align:middle; ">현재 비밀번호</caption>
			<caption id="caption2" style="left:9px; top:34px; width:84px; height:20px; text-align:right; vertical-align:middle; ">새 비밀번호</caption>
			<caption id="caption3" style="left:9px; top:59px; width:84px; height:20px; text-align:right; vertical-align:middle; ">비밀번호 확인</caption>
			<button id="button1" style="left:114px; top:84px; width:55px; height:20px; ">
				<caption>닫기</caption>
				<script type="javascript" ev:event="onclick">
					<![CDATA[
						oldPass.value = "";
						newPass1.value ="";
						newPass2.value = "";
						groupChangePW.visible = false;
					]]>
				</script>
			</button>
			<button id="button2" style="left:174px; top:84px; width:55px; height:20px; ">
				<caption>확인</caption>
				<script type="javascript" ev:event="onclick">
					<![CDATA[
						var userID = getUserID();
						var oldPassWord = oldPass.value;
						var newPassWord = newPass1.value;
						var newPassWord2 = newPass2.value;
						
						if (newPassWord != newPassWord2)
						{
							alertBox("새 비밀번호와 확인용 비밀번호가 동일하지 않습니다. ", "HISCM");
							model.setFocus("newPass2");
							return;
						}
						else 
						{					
							sendBuffInit();
							sendBuffAdd("UserID", userID);
							sendBuffAdd("oldPassWord", oldPassWord);
							sendBuffAdd("newPassWord", newPassWord);
							submit("sp_SCM_MemberShip", "ChangePass");
							
							var Result = model.getValue("/root/msgBuff/data/item/Result");
							if (Result == "OK")
							{
								groupChangePW.visible = false;
								alertBox("비밀번호가 변경되었습니다. ");
							} else {
								alertBox(Result);
								model.setFocus("oldPass");
							}
							
						}
					]]>
				</script>
			</button>
			<button id="button3" style="left:345px; top:-1px; width:130px; height:20px; ">
				<caption>도장사진 올리기</caption>
				<script type="javascript" ev:event="onclick">
					<![CDATA[
			
						var fileList = window.fileDialog("open", "|", true);
						var filename = fileList.split("|");
						
						if(fileList != ""){
							for (var i=0 ; i< filename.length ; i++) {
								model.alert(filename[i]);
							}
						}		
											
						upload("TrustBoard", "add", "0");
						var fileUid = model.getValue("/root/msgFiles/fileUID");
						model.setValue("/root/sendData/fileuid", fileUid);
								model.alert(fileUid);
					]]>
				</script>
			</button>
			<upload id="initUpload" nodeset="/root/sendData/STEMPSRC" style="left:479px; top:-1px; width:25px; height:20px; "/>
		</group>
	</xhtml:body>
</xhtml:html>
