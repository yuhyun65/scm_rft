# Database (container)
MSSQL_SA_PASSWORD=<REQUIRED_STRONG_PASSWORD>

# Service datasource/flyway standard
SCM_DB_URL=jdbc:sqlserver://localhost:1433;databaseName=scm_rft;encrypt=true;trustServerCertificate=true
SCM_DB_USER=sa
SCM_DB_PASSWORD=<REQUIRED_STRONG_PASSWORD>
SCM_DB_DRIVER=com.microsoft.sqlserver.jdbc.SQLServerDriver
SCM_FLYWAY_ENABLED=false
SCM_FLYWAY_LOCATIONS=filesystem:./migration/flyway
SCM_FLYWAY_TABLE=flyway_schema_history

# Auth/Gateway token policy
SCM_AUTH_JWT_SECRET=<REQUIRED_RANDOM_SECRET_MIN_32_CHARS>
SCM_AUTH_JWT_ISSUER=scm-auth
SCM_AUTH_ACCESS_TOKEN_EXP_SECONDS=1800
SCM_AUTH_LOGIN_MAX_FAILED_ATTEMPTS=5
SCM_AUTH_LOGIN_LOCK_MINUTES=15
GATEWAY_AUTH_VERIFY_URI=http://localhost:8081/api/auth/v1/tokens/verify
GATEWAY_AUTH_VERIFY_TIMEOUT_MS=1500
GATEWAY_AUTH_CB_SLIDING_WINDOW_SIZE=20
GATEWAY_AUTH_CB_MIN_CALLS=10
GATEWAY_AUTH_CB_FAILURE_RATE_THRESHOLD=50
GATEWAY_AUTH_CB_WAIT_OPEN_MS=10000
GATEWAY_AUTH_CB_HALF_OPEN_CALLS=3

# RabbitMQ
RABBITMQ_DEFAULT_USER=scm
RABBITMQ_DEFAULT_PASS=<REQUIRED_STRONG_PASSWORD>

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<REQUIRED_STRONG_PASSWORD>

# Common
TZ=Asia/Seoul
