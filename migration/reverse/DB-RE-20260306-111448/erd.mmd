    uniqueidentifier document_id PK
    nvarchar title
    nvarchar document_type
    datetime2 issued_at
    nvarchar publisher_member_id
    nvarchar status
    datetime2 created_at
    datetime2 updated_at
  }
  dbo_report_jobs {
    uniqueidentifier job_id PK
