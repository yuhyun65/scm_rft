# Production environment template (no insecure defaults)

# Database
SCM_DB_URL=jdbc:sqlserver://<sql-host>:1433;databaseName=<db-name>;encrypt=true;trustServerCertificate=false
SCM_DB_USER=<db-user>
SCM_DB_PASSWORD=<required-strong-password>
SCM_DB_DRIVER=com.microsoft.sqlserver.jdbc.SQLServerDriver
SCM_FLYWAY_ENABLED=true
SCM_FLYWAY_LOCATIONS=filesystem:./migration/flyway
SCM_FLYWAY_TABLE=flyway_schema_history

# Auth token policy
SCM_AUTH_JWT_SECRET=<required-random-secret-min-32-chars>
SCM_AUTH_JWT_ISSUER=scm-auth-prod
SCM_AUTH_ACCESS_TOKEN_EXP_SECONDS=1800
SCM_AUTH_LOGIN_MAX_FAILED_ATTEMPTS=5
SCM_AUTH_LOGIN_LOCK_MINUTES=15

# Cross-service endpoints
BOARD_FILE_SERVICE_BASE_URL=http://file:8087
GATEWAY_POLICY_PATH=infra/gateway/policies/cutover-isolation.yaml
GATEWAY_AUTH_VERIFY_URI=http://auth:8081/api/auth/v1/tokens/verify
GATEWAY_AUTH_VERIFY_TIMEOUT_MS=1500
GATEWAY_AUTH_CB_SLIDING_WINDOW_SIZE=20
GATEWAY_AUTH_CB_MIN_CALLS=10
GATEWAY_AUTH_CB_FAILURE_RATE_THRESHOLD=50
GATEWAY_AUTH_CB_WAIT_OPEN_MS=10000
GATEWAY_AUTH_CB_HALF_OPEN_CALLS=3
GATEWAY_EMERGENCY_STOP_ENABLED=false
GATEWAY_EMERGENCY_STOP_STATUS=503

# Infra users
MSSQL_SA_PASSWORD=<required-strong-password>
RABBITMQ_DEFAULT_USER=<rabbitmq-user>
RABBITMQ_DEFAULT_PASS=<required-strong-password>
GRAFANA_ADMIN_USER=<grafana-admin-user>
GRAFANA_ADMIN_PASSWORD=<required-strong-password>
TZ=Asia/Seoul
